  if (checkTrustedDevice()) {
    toast('⚡ Admin mode — trusted device', 'success');
  }
  // Show admin login button for non-admin users
  const switchBtn = document.getElementById('admin-switch-btn');
  if (switchBtn && !isAdmin()) switchBtn.style.display = 'flex';
  renderAll();
  updateStats();
  hideAppLoading();
  setBfTab('art');
  if (window.innerWidth <= 768) {
