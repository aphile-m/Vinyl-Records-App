}

function updateDetailDescStatus(r) {
  const badge = document.getElementById('d-desc-status-badge');
  const btn   = document.getElementById('d-verify-desc-btn');
  if (!badge) return;
  if (!r.albumDesc) { badge.textContent = ''; if(btn) btn.style.display='none'; return; }
  if (r.descStatus === 'verified') {
    badge.innerHTML = '<span class="desc-status-badge status-verified">✓ Verified</span>';
    if (btn) btn.style.display = 'none';
  } else if (r.descStatus === 'auto') {
    badge.innerHTML = '<span class="desc-status-badge status-auto">◑ Auto</span>';
    if (btn && isAdmin()) { btn.style.display = 'inline-flex'; btn.textContent = '✓ Verify'; }
  } else {
    badge.textContent = '';
    if (btn && isAdmin()) { btn.style.display = 'inline-flex'; btn.textContent = '✓ Mark Verified'; }
  }
}

