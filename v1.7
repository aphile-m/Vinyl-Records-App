function toggleListened() {
  if (!currentRecord || !isAdmin()) { if(!isAdmin()) toast('Admin access required','error'); return; }
  currentRecord.listened = !currentRecord.listened;
  if (currentRecord.listened) {
    // Increment play count and log session
    currentRecord.playCount = (currentRecord.playCount || 0) + 1;
    logSession(currentRecord);
  }
  saveRecord(currentRecord);
  document.getElementById('d-listen-btn').textContent = currentRecord.listened ? '✓ Mark Unlistened' : '◎ Mark as Listened';
  document.getElementById('d-play-count').textContent = currentRecord.playCount ? `▶ ${currentRecord.playCount}×` : '';
  renderAll();
  toast(currentRecord.listened ? `✓ Listened — played ${currentRecord.playCount}×` : 'Marked as unlistened');
}

function logSession(r) {
  const log = JSON.parse(localStorage.getItem('mrd_sessions') || '[]');
  log.unshift({ id: r.id, artist: r.artist, title: r.title, art: r.albumArt, ts: Date.now() });
  if (log.length > 200) log.splice(200);
  localStorage.setItem('mrd_sessions', JSON.stringify(log));
}

function toggleFavourite() {
  if (!currentRecord || !isAdmin()) { if(!isAdmin()) toast('Admin access required','error'); return; }
  currentRecord.favourite = !currentRecord.favourite;
  saveDB();
  document.getElementById('d-fav-btn').textContent = currentRecord.favourite ? '★ Unfavourite' : '☆ Favourite';
  renderAll();
  toast(currentRecord.favourite ? '★ Added to favourites' : 'Removed from favourites');
}

function addTrack() {
  if (!isAdmin()) return;
  const input = document.getElementById('track-add-input');
  const name = input.value.trim();
  if (!name || !currentRecord) return;
  currentRecord.trackList = currentRecord.trackList || [];
  currentRecord.trackList.push(name);
  saveDB();
  input.value = '';
  renderDetailTracks();
}

function removeTrack(i, e) {
  e.stopPropagation();
  if (!currentRecord || !isAdmin()) return;
  currentRecord.trackList.splice(i,1);
  if (currentRecord.favTracks) currentRecord.favTracks = currentRecord.favTracks.filter(x=>x!==i).map(x=>x>i?x-1:x);
  saveDB(); renderDetailTracks();
}

function toggleTrackFav(i, e) {
  e.stopPropagation();
  if (!currentRecord) return;
  currentRecord.favTracks = currentRecord.favTracks || [];
  const idx = currentRecord.favTracks.indexOf(i);
  if (idx === -1) currentRecord.favTracks.push(i);
  else currentRecord.favTracks.splice(idx,1);
  saveDB(); renderDetailTracks();
}

function saveEdit() {
  if (!isAdmin() || !currentRecord) return;
  currentRecord.artist = document.getElementById('e-artist').value.trim();
  currentRecord.title = document.getElementById('e-title').value.trim();
  currentRecord.genre = document.getElementById('e-genre').value.trim();
  currentRecord.year = +document.getElementById('e-year').value || null;
  currentRecord.label = document.getElementById('e-label').value.trim();
  currentRecord.notes = document.getElementById('e-notes').value.trim();
  saveDB(); renderAll();
  toast('Record updated ✓');
  openDetail(currentRecord.id);
}

function saveNotes() {
  if (!currentRecord || !isAdmin()) return;
  currentRecord.albumDesc = document.getElementById('d-notes-area').value;
  saveDB();
}

