<!-- OCR Modal -->
<div id="ocr-modal" style="position:fixed;inset:0;z-index:350;background:rgba(0,0,0,.9);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s">
