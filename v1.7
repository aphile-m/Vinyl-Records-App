}

// ═══════════════════════════════════════════════════════
// LYRICS FETCH (lyrics.ovh + Genius fallback link)
// ═══════════════════════════════════════════════════════
async function fetchLyricsForTrack(idx) {
  if (!currentRecord || !isAdmin()) return;
  const tracks = currentRecord.trackList || [];
  const obj = trackObj(tracks[idx]);
  const name = obj.name || obj;
  toast(`🎤 Fetching lyrics for "${name}"…`);

  try {
    const res = await fetch(
      `https://api.lyrics.ovh/v1/${encodeURIComponent(currentRecord.artist)}/${encodeURIComponent(name)}`
    );
    if (res.ok) {
      const data = await res.json();
      if (data.lyrics && data.lyrics.trim().length > 20) {
        tracks[idx] = { ...obj, lyrics: data.lyrics.trim(), lyricsPartial: false };
        currentRecord.trackList = tracks;
        saveRecord(currentRecord);
        renderTrackPage(idx);
        toast('Lyrics loaded ✓');
        return;
      }
    }
  } catch(e) {}

  // Fallback: no lyrics found, update UI with Genius link
  toast('Lyrics not found — try Genius link below', 'error');
  renderTrackPage(idx); // re-render to show Genius button
}

// ═══════════════════════════════════════════════════════
// TRACK ENRICHMENT (MusicBrainz credits)
// ═══════════════════════════════════════════════════════
async function enrichSingleTrack(idx) {
  if (!currentRecord || !isAdmin()) return;
  const tracks = currentRecord.trackList || [];
  const obj = trackObj(tracks[idx]);
  const name = obj.name || obj;
  toast(`⚡ Enriching "${name}"…`);

  try {
    // Search for recording on MusicBrainz
    const q = encodeURIComponent(`recording:"${name}" artist:"${currentRecord.artist}"`);
    const res = await fetch(
      `https://musicbrainz.org/ws/2/recording/?query=${q}&limit=3&fmt=json`,
      { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
    );
    if (!res.ok) throw new Error('MB error');
    const data = await res.json();
    if (!data.recordings?.length) throw new Error('Not found');

    const rec = data.recordings[0];
    const duration = rec.length ? formatDuration(rec.length) : obj.duration;

    // Fetch full recording details with relations
    await new Promise(r => setTimeout(r, 400));
    const detRes = await fetch(
      `https://musicbrainz.org/ws/2/recording/${rec.id}?inc=artist-credits+work-rels+recording-rels&fmt=json`,
      { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
    );
    const det = await detRes.json();

    // Extract writer info from relations
    const writers = [];
    const producers = [];
    if (det.relations) {
      det.relations.forEach(rel => {
        if (['composer','lyricist','writer'].includes(rel.type)) {
          if (rel.artist?.name) writers.push(rel.artist.name);
        }
        if (['producer','co-producer'].includes(rel.type)) {
          if (rel.artist?.name) producers.push(rel.artist.name);
        }
      });
    }

    tracks[idx] = {
      ...obj,
      duration: duration || obj.duration,
      writers: writers.length ? writers.join(', ') : obj.writers,
      producers: producers.length ? producers.join(', ') : obj.producers,
      mbid: rec.id,
      enriched: true
    };
    currentRecord.trackList = tracks;
    saveRecord(currentRecord);
    renderDetailTracks();
    renderTrackPage(idx);
    toast(`✓ "${name}" enriched`);
  } catch(e) {
    toast(`Could not find credits for "${name}" on MusicBrainz`, 'error');
  }
}

async function enrichAllTracks() {
  if (!currentRecord || !isAdmin()) return;
  const tracks = currentRecord.trackList || [];
  const toEnrich = tracks.filter((t, i) => !trackObj(t).enriched);
  if (!toEnrich.length) { toast('All tracks already enriched'); return; }
  toast(`⚡ Enriching ${toEnrich.length} tracks — this may take a minute…`);
  for (let i = 0; i < tracks.length; i++) {
    if (!trackObj(tracks[i]).enriched) {
      await enrichSingleTrack(i);
      await new Promise(r => setTimeout(r, 1000));
    }
  }
  toast(`✓ All tracks enriched`);
}

function formatDuration(ms) {
  const s = Math.round(ms / 1000);
  return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;
}

