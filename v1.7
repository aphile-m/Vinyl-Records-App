function renderNpTracks() {
  const container = document.getElementById('np-tracks');
  const tracks = npRecord?.trackList || [];
  if (!tracks.length) { container.innerHTML = '<div style="color:var(--text3);font-size:.8rem">No tracks listed</div>'; return; }
  container.innerHTML = tracks.map((t, i) => `
    <div class="np-track ${npDoneTracks.has(i) ? 'done' : ''}" onclick="toggleNpTrack(${i})">
      <span class="np-track-num">${i+1}</span>
      <span class="np-track-name">${t}</span>
      <span class="np-track-check">✓</span>
    </div>`).join('');
