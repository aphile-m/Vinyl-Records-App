// ── Supabase helpers ──────────────────────────────────
async function sbFetch(path, opts = {}) {
  const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
    ...opts,
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
      'Content-Type': 'application/json',
      'Prefer': opts.prefer || 'return=representation',
      ...opts.headers
    }
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`Supabase ${res.status}: ${err}`);
  }
  const text = await res.text();
  return text ? JSON.parse(text) : null;
}

function recordToRow(r) {
  return {
    id:          r.id,
    artist:      r.artist,
    title:       r.title,
    genre:       r.genre,
    year:        r.year,
    label:       r.label,
    notes:       r.notes,
    favourite:   r.favourite  || false,
    listened:    r.listened   || false,
    album_art:   r.albumArt   || null,
    art_status:  r.artStatus  || null,
    bio_status:  r.bioStatus   || null,
    desc_status: r.descStatus  || null,
    track_list:  r.trackList  || [],
    fav_tracks:  r.favTracks  || [],
    artist_bio:  r.artistBio  || '',
    album_desc:  r.albumDesc  || '',
    play_count:  r.playCount  || 0,
    tags:        r.tags       || []
  };
}

function rowToRecord(row) {
  // Merge with INITIAL_DATA defaults so all fields always exist
  const base = INITIAL_DATA.find(r => r.id === row.id) || {};
  return {
    ...base,
    id:         row.id,
    artist:     row.artist     ?? base.artist     ?? '',
    title:      row.title      ?? base.title      ?? '',
    genre:      row.genre      ?? base.genre      ?? '',
    year:       row.year       ?? base.year       ?? null,
    label:      row.label      ?? base.label      ?? '',
    notes:      row.notes      ?? base.notes      ?? '',
    favourite:  row.favourite  ?? false,
    listened:   row.listened   ?? false,
    albumArt:   row.album_art  ?? null,
    artStatus:  row.art_status ?? null,
    bioStatus:  row.bio_status  ?? null,
    descStatus: row.desc_status ?? null,
    trackList:  row.track_list ?? [],
    favTracks:  row.fav_tracks ?? [],
    artistBio:  row.artist_bio ?? '',
    albumDesc:  row.album_desc ?? '',
    playCount:  row.play_count  ?? 0,
    tags:       row.tags        ?? []
  };
}

