  document.getElementById('artpicker-modal').classList.remove('open');
  selectedArtUrl = null;
  toast('Album art saved & verified ✓');
}

// ═══════════════════════════════════════════════════════
// TRACKLIST FETCH (MusicBrainz)
// ═══════════════════════════════════════════════════════
async function fetchTracklist() {
  if (!currentRecord || !isAdmin()) return;
  const container = document.getElementById('tracklist-search-results');
  container.innerHTML = '<div style="color:var(--text2);font-size:.85rem"><span class="loading-spinner"></span> Fetching tracklist via AI…</div>';

  // First try MusicBrainz directly (it supports CORS natively)
  let mbTracks = null;
  try {
    const q = encodeURIComponent(`release:"${currentRecord.title}" artist:"${currentRecord.artist}"`);
    const res = await fetch(
      `https://musicbrainz.org/ws/2/release/?query=${q}&limit=3&fmt=json`,
      { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
    );
    const data = await res.json();
    if (data.releases?.length) {
      const rel = data.releases[0];
      const detRes = await fetch(
        `https://musicbrainz.org/ws/2/release/${rel.id}?inc=recordings&fmt=json`,
        { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
      );
      const det = await detRes.json();
      const tracks = [];
      if (det.media) det.media.forEach(m => m.tracks?.forEach(t => tracks.push(t.title)));
      if (tracks.length) {
        mbTracks = { tracks, source: `MusicBrainz — ${rel.title} (${rel.date||'?'})` };
      }
    }
  } catch(e) {}

  if (mbTracks) {
    showTracklistResult(container, mbTracks.tracks, mbTracks.source);
    return;
  }

  // Broader MusicBrainz search — try just title without quotes
  try {
    const q2 = encodeURIComponent(`${currentRecord.title} ${currentRecord.artist}`);
    const res2 = await fetch(
      `https://musicbrainz.org/ws/2/release/?query=${q2}&limit=3&fmt=json`,
      { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
    );
    const data2 = await res2.json();
    if (data2.releases?.length) {
      for (const rel of data2.releases.slice(0, 3)) {
        const detRes = await fetch(
          `https://musicbrainz.org/ws/2/release/${rel.id}?inc=recordings&fmt=json`,
          { headers: { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' } }
        );
        const det = await detRes.json();
        const tracks = [];
        if (det.media) det.media.forEach(m => m.tracks?.forEach(t => tracks.push(t.title)));
        if (tracks.length) {
          showTracklistResult(container, tracks, `MusicBrainz — ${rel.title} (${rel.date||'?'})`);
          return;
        }
        await new Promise(r => setTimeout(r, 200));
      }
    }
  } catch(e) {}

  container.innerHTML = `<div style="color:var(--text3);font-size:.85rem">
    Tracklist not found in MusicBrainz. Add tracks manually using the field above, or use the 📷 OCR photo option.
  </div>`;
}

function showTracklistResult(container, tracks, source) {
  container.innerHTML = '';
  const div = document.createElement('div');
  div.className = 'tracklist-search-result';
  div.innerHTML = `
    <div class="tracklist-source">${source}</div>
    <ol class="tracklist-tracks">${tracks.map((t,i)=>`<li><span>${i+1}.</span>${t}</li>`).join('')}</ol>
    <button class="btn btn-primary btn-sm" style="margin-top:10px" id="apply-tracks-btn">✓ Apply this tracklist</button>
  `;
  div.querySelector('#apply-tracks-btn').onclick = (e) => {
    e.stopPropagation();
    if (!confirm(`Apply ${tracks.length} tracks to "${currentRecord.title}"?`)) return;
    currentRecord.trackList = tracks;
    saveDB(); renderDetailTracks();
    container.innerHTML = `<div style="color:var(--success);font-size:.85rem">✓ Applied ${tracks.length} tracks.</div>`;
    toast(`✓ Applied ${tracks.length} tracks`);
  };
  container.appendChild(div);
}

// ═══════════════════════════════════════════════════════
// ARTIST BIO & ALBUM DESC (Wikipedia / LastFM-style)
// ═══════════════════════════════════════════════════════
async function fetchArtistBio() {
  if (!currentRecord || !isAdmin()) return;
  const bioEl = document.getElementById('d-artist-bio');
  bioEl.innerHTML = '<span class="loading-spinner"></span> Searching Wikipedia…';

  const artist = currentRecord.artist;
  // Strip "The " prefix and "feat." suffixes for better search hits
  const cleanArtist = artist.replace(/^The /i,'').replace(/\s+feat\..*$/i,'').trim();

  const searches = [cleanArtist, artist, `${cleanArtist} musician`, `${cleanArtist} singer`];

  for (const term of searches) {
    try {
      const searchRes = await fetch(
        `https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(term)}&srlimit=5&format=json&origin=*`
      );
      if (!searchRes.ok) throw new Error(`HTTP ${searchRes.status}`);
      const searchData = await searchRes.json();
      const results = searchData?.query?.search || [];
      if (!results.length) continue;

      // Pick best result — prefer one whose title contains the artist name
      const best = results.find(r =>
        r.title.toLowerCase().includes(cleanArtist.toLowerCase())
      ) || results[0];

      const extractRes = await fetch(
        `https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exintro&explaintext&exsentences=12&pageids=${best.pageid}&format=json&origin=*`
      );
      if (!extractRes.ok) throw new Error(`HTTP ${extractRes.status}`);
      const extractData = await extractRes.json();
      const pages = extractData?.query?.pages || {};
      const extract = pages[Object.keys(pages)[0]]?.extract?.trim() || '';

      if (extract.length < 50) continue;

      const paras = extract.split('\n').map(p=>p.trim()).filter(p=>p.length > 30).slice(0,4);
      const text = paras.join('\n\n');

      currentRecord.artistBio = text;
      currentRecord.bioStatus = 'auto';
      saveRecord(currentRecord);
      bioEl.innerHTML = `<p style="font-size:.72rem;color:var(--text3);margin-bottom:8px">Source: Wikipedia — "${best.title}"</p>` +
        paras.map(p=>`<p>${p}</p>`).join('');
      updateDetailBioStatus(currentRecord);
      toast('Biography loaded ✓');
      return;
    } catch(e) {
      console.warn('Bio fetch attempt failed:', term, e.message);
    }
  }

  bioEl.innerHTML = `<div style="color:var(--text2);font-size:.88rem;line-height:1.7">
    No Wikipedia entry found for <strong>${artist}</strong>.<br>
    You can type a biography manually in the <strong>Notes</strong> tab.
  </div>`;
}

async function fetchAlbumDesc() {
  if (!currentRecord || !isAdmin()) return;
  const descEl = document.getElementById('d-album-desc');
  descEl.innerHTML = '<span class="loading-spinner"></span> Searching Wikipedia…';

  const { artist, title, year } = currentRecord;
  const cleanArtist = artist.replace(/^The /i,'').replace(/\s+feat\..*$/i,'').trim();

  const searches = [
    `${title} ${cleanArtist}`,
    `${title} album`,
    `${title} ${year||''}`.trim(),
    title
  ];

  for (const term of searches) {
    try {
      const searchRes = await fetch(
        `https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(term)}&srlimit=5&format=json&origin=*`
      );
      if (!searchRes.ok) throw new Error(`HTTP ${searchRes.status}`);
      const searchData = await searchRes.json();
      const results = searchData?.query?.search || [];
      if (!results.length) continue;

      // Pick best result — prefer one whose title matches the album title
      const best = results.find(r =>
        r.title.toLowerCase().includes(title.toLowerCase().split(' ').slice(0,3).join(' '))
      ) || results[0];

      const extractRes = await fetch(
        `https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exintro&explaintext&exsentences=10&pageids=${best.pageid}&format=json&origin=*`
      );
      if (!extractRes.ok) throw new Error(`HTTP ${extractRes.status}`);
      const extractData = await extractRes.json();
      const pages = extractData?.query?.pages || {};
      const extract = pages[Object.keys(pages)[0]]?.extract?.trim() || '';

      if (extract.length < 50) continue;

      // Loose relevance check — just needs artist OR album word OR "album"/"record"
      const lc = extract.toLowerCase();
      const artistWord = cleanArtist.toLowerCase().split(' ')[0];
      const titleWord = title.toLowerCase().split(' ').filter(w=>w.length>3)[0] || title.split(' ')[0].toLowerCase();
      if (!lc.includes(artistWord) && !lc.includes(titleWord) && !lc.includes('album') && !lc.includes('record') && !lc.includes('music')) continue;

      const paras = extract.split('\n').map(p=>p.trim()).filter(p=>p.length > 30).slice(0,3);
      const text = paras.join('\n\n');

      currentRecord.albumDesc = text;
      currentRecord.descStatus = 'auto';
      saveRecord(currentRecord);
      descEl.innerHTML = `<p style="font-size:.72rem;color:var(--text3);margin-bottom:8px">Source: Wikipedia — "${best.title}"</p>` +
        paras.map(p=>`<p>${p}</p>`).join('');
      const notesArea = document.getElementById('d-notes-area');
      if (notesArea) notesArea.value = text;
      updateDetailDescStatus(currentRecord);
      toast('Description loaded ✓');
      return;
    } catch(e) {
      console.warn('Album desc fetch attempt failed:', term, e.message);
    }
  }

  descEl.innerHTML = `<div style="color:var(--text2);font-size:.88rem;line-height:1.7">
    No Wikipedia entry found for <strong>${title}</strong>.<br>
    You can write a description manually in the <strong>Notes</strong> tab.
  </div>`;
}

// ═══════════════════════════════════════════════════════
// OCR (via free OCR API)
// ═══════════════════════════════════════════════════════
function openOCR() {
  if (!isAdmin()) return;
  document.getElementById('ocr-modal').style.opacity = '1';
  document.getElementById('ocr-modal').style.pointerEvents = 'all';
  document.getElementById('ocr-preview').classList.add('hidden');
  document.getElementById('ocr-status').textContent = '';
  document.getElementById('ocr-result-tracks').innerHTML = '';
  document.getElementById('ocr-apply-btn').classList.add('hidden');
  document.getElementById('ocr-file').value = '';
  ocrExtractedTracks = [];
}

function closeOCR() {
  document.getElementById('ocr-modal').style.opacity = '0';
  document.getElementById('ocr-modal').style.pointerEvents = 'none';
}

async function handleOCRFile(e) {
  const file = e.target.files[0];
  if (!file) return;
  const preview = document.getElementById('ocr-preview');
  const reader = new FileReader();
  reader.onload = async (ev) => {
    preview.src = ev.target.result;
    preview.classList.remove('hidden');
    await runOCR(file, ev.target.result);
  };
  reader.readAsDataURL(file);
}

async function runOCR(file, dataUrl) {
  const status = document.getElementById('ocr-status');
  status.innerHTML = '<span class="loading-spinner"></span> Processing image with OCR…';
  try {
    const base64 = dataUrl.split(',')[1];
    const res = await fetch('https://api.ocr.space/parse/image', {
      method: 'POST',
      headers: {'apikey': 'K81234567890', 'Content-Type': 'application/x-www-form-urlencoded'},
      body: `base64Image=data:image/jpeg;base64,${base64}&language=eng&isTable=false`
    });
    const data = await res.json();
    let text = '';
    if (data.ParsedResults && data.ParsedResults[0]) text = data.ParsedResults[0].ParsedText;
    if (!text) throw new Error('No text');
    processOCRText(text);
  } catch(e) {
    // Fallback: show manual entry
    status.textContent = 'OCR service unavailable. Please review and manually enter track names below.';
    document.getElementById('ocr-result-tracks').innerHTML = `<textarea id="ocr-manual" style="width:100%;height:120px;margin-top:8px;font-size:.85rem" placeholder="Paste or type track names, one per line…"></textarea>`;
    document.getElementById('ocr-apply-btn').classList.remove('hidden');
    ocrExtractedTracks = [];
  }
}

function processOCRText(text) {
  const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 2 && l.length < 100);
  const trackLines = lines.filter(l => !l.match(/^[0-9]{4}$/) && !l.match(/^(side|label|rpm|stereo|mono)/i));
  ocrExtractedTracks = trackLines.map(l => l.replace(/^\d+[\.\)]\s*/, '').replace(/\s+\d+:\d+$/, '').trim()).filter(Boolean);
  const container = document.getElementById('ocr-result-tracks');
  const status = document.getElementById('ocr-status');
  status.textContent = `Found ${ocrExtractedTracks.length} potential track names. Edit below before applying:`;
  container.innerHTML = `<textarea id="ocr-edit" style="width:100%;height:140px;margin-top:8px;font-size:.83rem">${ocrExtractedTracks.join('\n')}</textarea>`;
  document.getElementById('ocr-apply-btn').classList.remove('hidden');
}

function applyOCRTracks() {
  if (!currentRecord) return;
  const editArea = document.getElementById('ocr-edit') || document.getElementById('ocr-manual');
  const lines = (editArea ? editArea.value : ocrExtractedTracks.join('\n')).split('\n').map(l=>l.trim()).filter(Boolean);
  if (!lines.length) { toast('No tracks to apply', 'error'); return; }
  if (!confirm(`Apply ${lines.length} tracks to "${currentRecord.title}"?`)) return;
  currentRecord.trackList = lines;
  saveDB(); renderDetailTracks();
  closeOCR();
  toast(`✓ Applied ${lines.length} tracks from image`);
}

// ═══════════════════════════════════════════════════════
// SPINNING WHEEL
// ═══════════════════════════════════════════════════════
function openWheel() {
  document.getElementById('wheel-modal').classList.add('open');
  drawWheel();
  updateWheelInfo();
}

function closeWheel() {
  document.getElementById('wheel-modal').classList.remove('open');
}

function getWheelRecords() {
  return DB.filter(r => !r.listened);
}

function updateWheelInfo() {
  const pool = getWheelRecords();
  document.getElementById('wheel-exclude-info').textContent = `${pool.length} unlistened records in the pool. ${DB.length - pool.length} already listened.`;
}

function drawWheel(highlightIndex = -1, angle = 0) {
  const canvas = document.getElementById('wheel-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2, r = W/2 - 8;
  const records = getWheelRecords();
  if (!records.length) {
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = '#2a2a2a'; ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = '#a09890'; ctx.font = '16px DM Sans'; ctx.textAlign = 'center';
    ctx.fillText('All records listened!', cx, cy);
    return;
  }
  const slice = (Math.PI*2) / records.length;
  const colors = ['#e8c547','#c47b2e','#4a8fd4','#9b59b6','#e05252','#52c478','#d4598a','#3a7bd5'];
  ctx.clearRect(0,0,W,H);
  records.forEach((rec, i) => {
    const start = angle + i * slice;
    const end = start + slice;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, start, end);
    ctx.fillStyle = i === highlightIndex ? '#f0f0f0' : colors[i % colors.length];
    ctx.fill();
    ctx.strokeStyle = '#0a0a0a'; ctx.lineWidth = 2; ctx.stroke();

    // Label
    if (records.length <= 30) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(start + slice/2);
      ctx.textAlign = 'right';
      ctx.fillStyle = i === highlightIndex ? '#000' : 'rgba(0,0,0,0.8)';
      ctx.font = `bold ${Math.min(11, 280/records.length)}px DM Sans`;
      const label = rec.artist.length > 14 ? rec.artist.substring(0,12)+'…' : rec.artist;
      ctx.fillText(label, r - 8, 4);
      ctx.restore();
    }
  });

  // Center circle
  ctx.beginPath(); ctx.arc(cx,cy,28,0,Math.PI*2);
  ctx.fillStyle = '#0a0a0a'; ctx.fill();
  ctx.strokeStyle = '#e8c547'; ctx.lineWidth = 2; ctx.stroke();
  ctx.fillStyle = '#e8c547'; ctx.font = 'bold 18px Bebas Neue'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText('MRD', cx, cy);

  // Pointer
  ctx.beginPath();
  ctx.moveTo(cx + r + 6, cy);
  ctx.lineTo(cx + r - 16, cy - 10);
  ctx.lineTo(cx + r - 16, cy + 10);
  ctx.fillStyle = '#fff'; ctx.fill();
}

let wheelAngle = 0;
function spinWheel() {
  if (wheelSpinning) return;
  const records = getWheelRecords();
  if (!records.length) { toast('All records have been listened to!'); return; }
  wheelSpinning = true;
  document.getElementById('spin-btn').disabled = true;
  document.getElementById('wheel-result').innerHTML = '';

  const totalRotation = (Math.PI * 2 * (8 + Math.random() * 6));
  const duration = 4000;
  const startTime = Date.now();
  const startAngle = wheelAngle;

  function animate() {
    const elapsed = Date.now() - startTime;
    const progress = Math.min(elapsed / duration, 1);
    const ease = 1 - Math.pow(1 - progress, 4);
    wheelAngle = startAngle + totalRotation * ease;
    drawWheel(-1, wheelAngle);

    if (progress < 1) {
      requestAnimationFrame(animate);
    } else {
      // Determine winner
      const slice = (Math.PI * 2) / records.length;
      const normalised = ((2 * Math.PI) - (wheelAngle % (Math.PI * 2))) % (Math.PI * 2);
      const winnerIdx = Math.floor(normalised / slice) % records.length;
      const winner = records[winnerIdx];
      drawWheel(winnerIdx, wheelAngle);

      document.getElementById('wheel-result').innerHTML = `
        <div style="color:var(--text3);font-size:.8rem;margin-bottom:4px">🎵 Tonight's record:</div>
        <div class="wr-artist">${winner.artist}</div>
        <div class="wr-title">${winner.title}${winner.year ? ` (${winner.year})` : ''}</div>
        <button class="btn btn-primary btn-sm" style="margin-top:12px" onclick="markWheelWinner('${winner.id}')">✓ Mark as Listened</button>
      `;
      wheelSpinning = false;
      document.getElementById('spin-btn').disabled = false;
    }
  }
  requestAnimationFrame(animate);
}

function markWheelWinner(id) {
  if (!isAdmin()) { toast('Admin access required to mark as listened', 'error'); return; }
  const r = DB.find(x => x.id === id);
  if (r) { r.listened = true; saveRecord(r); updateWheelInfo(); drawWheel(); renderAll(); toast('Marked as listened ✓'); }
}

async function resetWheelListened() {
  if (!isAdmin()) { toast('Admin access required', 'error'); return; }
  if (!confirm('Reset all listened status? This cannot be undone.')) return;
  DB.forEach(r => r.listened = false);
  await saveBulk(DB);
  updateWheelInfo(); drawWheel(); renderAll();
  toast('All listened status reset');
}

