// ═══════════════════════════════════════════════════════
function openArtPicker() {
  if (!isAdmin()) return;
  selectedArtUrl = null;
  const btn = document.getElementById('artpicker-confirm');
  btn.disabled = true;
  btn.textContent = 'Confirm Art';
  document.getElementById('artpicker-results').innerHTML = '';
  document.getElementById('artpicker-url').value = '';
  if (currentRecord) {
    document.getElementById('artpicker-query').value = `${currentRecord.artist} ${currentRecord.title}`;
    searchArt();
  }
  document.getElementById('artpicker-modal').classList.add('open');
}

function closeArtPicker() {
  document.getElementById('artpicker-modal').classList.remove('open');
}

async function searchArt() {
  const query = document.getElementById('artpicker-query').value.trim();
  if (!query) return;
  const container = document.getElementById('artpicker-results');
  container.innerHTML = '<div style="color:var(--text3);font-size:.85rem">🔍 Searching iTunes…</div>';

  let results = [];

  // iTunes has native CORS (Access-Control-Allow-Origin: *) - call directly, no proxy needed
  try {
    const res = await fetch(
      `https://itunes.apple.com/search?term=${encodeURIComponent(query)}&entity=album&limit=24&media=music`
    );
    const data = await res.json();
    if (data.results?.length) {
      results = data.results
        .filter(i => i.artworkUrl100)
        .map(i => i.artworkUrl100.replace('100x100bb','600x600bb'));
    }
  } catch(e) {}

  if (results.length > 0) {
    renderArtResults(container, results);
    return;
  }

  // iTunes unavailable — show manual instructions with helpful links
  container.innerHTML = `
    <div style="color:var(--text2);font-size:.85rem;line-height:1.9">
      <strong>Couldn't find art automatically.</strong> Here's how to add it manually:<br>
      1. Open <a href="https://www.discogs.com/search/?q=${encodeURIComponent(query)}&type=release" target="_blank" style="color:var(--accent)">Discogs ↗</a> or <a href="https://music.apple.com/search?term=${encodeURIComponent(query)}" target="_blank" style="color:var(--accent)">Apple Music ↗</a><br>
      2. Find the album cover image<br>
      3. Right-click → <em>Copy Image Address</em><br>
      4. Paste the URL in the field below and click <strong>Use URL</strong>
    </div>`;
}

function renderArtResults(container, urls) {
  container.innerHTML = '';
  if (!urls.length) {
    container.innerHTML = '<div style="color:var(--text3);font-size:.85rem">No images found.</div>';
    return;
  }
  urls.forEach(url => {
    const div = document.createElement('div');
    div.className = 'artpicker-item';
    div.style.cssText = 'cursor:pointer;border-radius:8px;overflow:hidden;border:2px solid transparent;transition:all .2s;aspect-ratio:1;background:var(--surface2);';
    const img = document.createElement('img');
    img.src = url;
    img.loading = 'lazy';
    img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    img.onerror = () => div.remove();
    div.appendChild(img);
    div.addEventListener('click', (e) => { e.stopPropagation();
      // Deselect all
      container.querySelectorAll('div[data-art]').forEach(x => {
        x.style.borderColor = 'transparent';
        x.style.boxShadow = 'none';
      });
      // Select this one
      div.style.borderColor = '#52c478';
      div.style.boxShadow = '0 0 0 2px #52c478';
      div.setAttribute('data-art', url);
      selectedArtUrl = url;
      const btn = document.getElementById('artpicker-confirm');
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.textContent = '✓ Confirm Art';
    });
    div.setAttribute('data-art', url);
    container.appendChild(div);
  });
}

function setArtFromUrl() {
  const url = document.getElementById('artpicker-url').value.trim();
  if (!url) { toast('Please enter a URL first', 'error'); return; }
  selectedArtUrl = url;
  const btn = document.getElementById('artpicker-confirm');
  btn.disabled = false;
  btn.style.opacity = '1';
  btn.textContent = '✓ Confirm Art';
  toast('URL set — click Confirm Art to save');
}

function confirmArt() {
  const url = selectedArtUrl;
  const record = currentRecord;
  if (!url) { toast('Please select an image first', 'error'); return; }
  if (!record) { toast('No record open — please close and reopen the record', 'error'); return; }
  record.albumArt = url;
  record.artStatus = 'verified';
  saveDB();
  renderAll();
  const artImg = document.getElementById('d-art-img');
  const artPh = document.getElementById('d-art-placeholder');
  if (artImg) { artImg.src = url; artImg.style.display = 'block'; }
  if (artPh) { artPh.style.display = 'none'; }
