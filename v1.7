  }
  window.addEventListener('resize', () => {
    document.getElementById('mobile-sidebar-btn').style.display = window.innerWidth <= 768 ? 'flex' : 'none';
  });
}

function showAppLoading(msg) {
  let el = document.getElementById('app-loading');
  if (!el) {
    el = document.createElement('div');
    el.id = 'app-loading';
    el.style.cssText = 'position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px';
    el.innerHTML = `<div style="font-family:\'Bebas Neue\',sans-serif;font-size:3rem;color:var(--accent);letter-spacing:.1em">MRD</div>
      <div class="loading-spinner" style="width:28px;height:28px;border-width:3px"></div>
      <div id="app-loading-msg" style="font-size:.85rem;color:var(--text2)"></div>`;
    document.body.appendChild(el);
  }
  document.getElementById('app-loading-msg').textContent = msg;
}

function hideAppLoading() {
  const el = document.getElementById('app-loading');
  if (el) { el.style.opacity = '0'; el.style.transition = 'opacity .4s'; setTimeout(() => el.remove(), 400); }
}

async function loadDB() {
  // 1. Show cached data instantly if available
  const cached = localStorage.getItem(STORAGE_KEY);
  if (cached) {
    try { DB = JSON.parse(cached); } catch(e) {}
  }

  // 2. Try loading from Supabase
  try {
    showAppLoading('Loading your collection…');
    const rows = await sbFetch('records?select=*&order=id.asc');

    if (rows && rows.length > 0) {
      // Build DB: start from INITIAL_DATA, overlay Supabase data
      const rowMap = {};
      rows.forEach(r => rowMap[r.id] = r);
      DB = INITIAL_DATA.map(initial => {
        return rowMap[initial.id] ? rowToRecord(rowMap[initial.id]) : { ...initial };
      });
      // Include any extra records in Supabase not in initial
      rows.forEach(r => { if (!DB.find(x => x.id === r.id)) DB.push(rowToRecord(r)); });
    } else {
      // First run — seed Supabase with all INITIAL_DATA
      showAppLoading('First run — seeding database…');
      DB = JSON.parse(JSON.stringify(INITIAL_DATA));
      await seedDatabase();
    }
    // Cache locally for instant next load
    localStorage.setItem(STORAGE_KEY, JSON.stringify(DB));
  } catch(e) {
    console.warn('Supabase unavailable, using local cache:', e.message);
    if (!DB.length) DB = JSON.parse(JSON.stringify(INITIAL_DATA));
    toast('Offline mode — changes will sync when reconnected', 'error');
  }
}

async function seedDatabase() {
  // Insert all records in batches of 20
  const batch = 20;
  for (let i = 0; i < INITIAL_DATA.length; i += batch) {
    const chunk = INITIAL_DATA.slice(i, i + batch).map(recordToRow);
    await sbFetch('records', {
      method: 'POST',
      prefer: 'return=minimal',
      body: JSON.stringify(chunk)
    });
  }
}

async function saveRecord(r) {
  // Update local DB and cache immediately (optimistic)
  const idx = DB.findIndex(x => x.id === r.id);
  if (idx !== -1) DB[idx] = r;
  localStorage.setItem(STORAGE_KEY, JSON.stringify(DB));

  // Push to Supabase in background
  try {
    await sbFetch(`records?id=eq.${encodeURIComponent(r.id)}`, {
      method: 'PATCH',
      prefer: 'return=minimal',
      body: JSON.stringify(recordToRow(r))
    });
  } catch(e) {
    console.warn('Save failed for', r.id, e.message);
  }
}

// Keep saveDB as a bulk cache save (no network call — use saveRecord for individual saves)
function saveDB() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(DB));
  // Sync current record to Supabase if one is open
  if (currentRecord) saveRecord(currentRecord);
}

// Push multiple records to Supabase in batches (used for bulk operations)
async function saveBulk(records) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(DB));
  const batch = 20;
  for (let i = 0; i < records.length; i += batch) {
    const chunk = records.slice(i, i + batch).map(recordToRow);
    try {
      await sbFetch('records', {
        method: 'POST',
        prefer: 'resolution=merge-duplicates,return=minimal',
        headers: { 'Prefer': 'resolution=merge-duplicates,return=minimal' },
        body: JSON.stringify(chunk)
      });
    } catch(e) { console.warn('Bulk save chunk failed:', e.message); }
    await new Promise(r => setTimeout(r, 100));
  }
}

