// BULK ART FETCH
// ═══════════════════════════════════════════════════════
// ── current bulk fetch mode ──────────────────────────────
let bfMode = 'art'; // 'art' | 'bio' | 'desc'

const BF_CONFIG = {
  art:     { label:'🖼 Album Art',     desc:'Searches iTunes for album art. Paced at ~1/sec (~3 min full catalogue). Only fetches records with NO art.',
             skip: r => !!(r.albumArt && r.albumArt.trim()), statusKey: 'artStatus', trackLevel: false },
  bio:     { label:'👤 Artist Bio',    desc:'Fetches artist biographies from Wikipedia. Only fetches records with NO bio text.',
             skip: r => !!(r.artistBio && r.artistBio.trim()), statusKey: 'bioStatus', trackLevel: false },
  desc:    { label:'📝 Album Info',    desc:'Fetches album descriptions from Wikipedia. Only fetches records with NO description.',
             skip: r => !!(r.albumDesc && r.albumDesc.trim()), statusKey: 'descStatus', trackLevel: false },
  tracks:  { label:'🎵 Tracklists',    desc:'Fetches track listings from MusicBrainz. Only fetches records with NO tracks.',
             skip: r => !!(r.trackList && r.trackList.length > 0), statusKey: null, trackLevel: false },
  credits: { label:'🎼 Track Credits', desc:'Enriches each track with writers, producers and duration from MusicBrainz. Skips tracks already enriched. ~2s per track.',
             skip: r => !(r.trackList && r.trackList.length > 0), statusKey: null, trackLevel: true,
             trackSkip: t => !!trackObj(t).enriched },
  lyrics:  { label:'🎤 Track Lyrics',  desc:'Fetches lyrics from lyrics.ovh for each track. Skips tracks that already have lyrics. ~800ms per track.',
             skip: r => !(r.trackList && r.trackList.length > 0), statusKey: null, trackLevel: true,
             trackSkip: t => !!trackObj(t).lyrics }
};

function setBfTab(mode) {
  bfMode = mode;
  document.querySelectorAll('.bf-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('bf-tab-' + mode).classList.add('active');
  const cfg = BF_CONFIG[mode];
  document.getElementById('bf-description').textContent = cfg.desc;
  resetBfCounts();
}

function resetBfCounts() {
  const cfg = BF_CONFIG[bfMode];
  let pending = 0;
  if (cfg.trackLevel) {
    // Count individual tracks that need fetching
    DB.forEach(r => {
      if (cfg.skip(r)) return;
      (r.trackList || []).forEach(t => { if (!cfg.trackSkip(t)) pending++; });
    });
  } else {
    pending = DB.filter(r => !cfg.skip(r)).length;
  }
  document.getElementById('bf-n-pending').textContent = pending;
  document.getElementById('bf-n-found').textContent = '0';
  document.getElementById('bf-n-notfound').textContent = '0';
  document.getElementById('bf-n-done').textContent = '0';
  document.getElementById('bf-progress').style.width = '0%';
  document.getElementById('bf-current').textContent = 'Ready. Press Start to begin.';
  document.getElementById('bf-log').innerHTML = '';
}

function openBulkFetch(mode) {
  if (!isAdmin()) return;
  bfMode = mode || 'art';
  bulkFetchAborted = false;
  document.getElementById('bf-start-btn').textContent = '▶ Start';
  document.getElementById('bf-start-btn').style.display = 'inline-flex';
  document.getElementById('bf-stop-btn').style.display = 'none';
  setBfTab(bfMode);
  document.getElementById('bulkfetch-modal').classList.add('open');
}

function closeBulkFetch() {
  bulkFetchAborted = true;
  document.getElementById('bulkfetch-modal').classList.remove('open');
  renderAll();
}

function stopBulkFetch() {
  bulkFetchAborted = true;
  document.getElementById('bf-current').textContent = 'Stopping after current record…';
  document.getElementById('bf-stop-btn').style.display = 'none';
}

function bfLog(msg, type='') {
  const log = document.getElementById('bf-log');
  const row = document.createElement('div');
  row.className = 'bf-log-row ' + type;
  row.textContent = msg;
  log.appendChild(row);
  log.scrollTop = log.scrollHeight;
}

async function startBulkFetch() {
  if (!isAdmin()) return;
  const cfg = BF_CONFIG[bfMode];
  bulkFetchAborted = false;
  document.getElementById('bf-start-btn').style.display = 'none';
  document.getElementById('bf-stop-btn').style.display = 'inline-flex';
  document.getElementById('bf-log').innerHTML = '';

  let found = 0, notFound = 0, skipped = 0, done = 0, total = 0;

  // ── Track-level modes (credits, lyrics) ─────────────
  if (cfg.trackLevel) {
    // Count total tracks to process
    const recordsWithTracks = DB.filter(r => !cfg.skip(r));
    recordsWithTracks.forEach(r => {
      (r.trackList || []).forEach(t => { if (!cfg.trackSkip(t)) total++; });
    });
    document.getElementById('bf-n-pending').textContent = total;

    for (const r of recordsWithTracks) {
      if (bulkFetchAborted) { bfLog('⏹ Stopped by user.', 'fail'); break; }
      const tracks = r.trackList || [];
      let recordChanged = false;

      for (let i = 0; i < tracks.length; i++) {
        if (bulkFetchAborted) break;
        const t = tracks[i];
        if (cfg.trackSkip(t)) continue; // already has data

        const obj = trackObj(t);
        const tname = obj.name || t;
        document.getElementById('bf-progress').style.width = Math.round((done / Math.max(total,1)) * 100) + '%';
        document.getElementById('bf-current').textContent = `${r.artist} — "${tname}"`;

        let result = null;
        if (bfMode === 'credits') result = await fetchCreditsForTrack(r, tname, i);
        if (bfMode === 'lyrics')  result = await fetchLyricsForTrackBulk(r, tname, i);

        if (result) {
          tracks[i] = result;
          found++;
          recordChanged = true;
          document.getElementById('bf-n-found').textContent = found;
          bfLog(`✓ ${r.artist} / "${tname}"`, 'ok');
        } else {
          notFound++;
          document.getElementById('bf-n-notfound').textContent = notFound;
          bfLog(`✗ ${r.artist} / "${tname}"`, 'fail');
        }

        done++;
        document.getElementById('bf-n-pending').textContent = Math.max(0, total - done);

        const delay = bfMode === 'credits' ? 1800 : 800;
        await new Promise(res => setTimeout(res, delay));
      }

      if (recordChanged) {
        r.trackList = tracks;
        saveRecord(r);
      }
    }

  // ── Record-level modes (art, bio, desc, tracks) ──────
  } else {
    const toFetch = DB.filter(r => !cfg.skip(r));
    total = toFetch.length;
    document.getElementById('bf-n-pending').textContent = total;

    for (let i = 0; i < toFetch.length; i++) {
      if (bulkFetchAborted) { bfLog('⏹ Stopped by user.', 'fail'); break; }

      const r = toFetch[i];
      document.getElementById('bf-progress').style.width = Math.round((i/total)*100) + '%';
      document.getElementById('bf-current').textContent = `[${i+1}/${total}] ${r.artist} — ${r.title}`;

      if (cfg.skip(r)) {
        skipped++; done++;
        document.getElementById('bf-n-done').textContent = skipped;
        bfLog(`⤼ ${r.artist} — ${r.title} (already has data)`, 'skip');
        continue;
      }

      let result = null;
      if (bfMode === 'art')    result = await fetchArtForRecord(r);
      if (bfMode === 'bio')    result = await fetchBioForRecord(r);
      if (bfMode === 'desc')   result = await fetchDescForRecord(r);
      if (bfMode === 'tracks') result = await fetchTracklistForRecord(r);

      if (result) {
        if (bfMode === 'art')    { r.albumArt  = result; r.artStatus  = 'auto'; }
        if (bfMode === 'bio')    { r.artistBio = result; r.bioStatus  = 'auto'; }
        if (bfMode === 'desc')   { r.albumDesc = result; r.descStatus = 'auto'; }
        if (bfMode === 'tracks') { r.trackList = result; }
        found++;
        document.getElementById('bf-n-found').textContent = found;
        bfLog(`✓ ${r.artist} — ${r.title}`, 'ok');
        saveRecord(r);
      } else {
        notFound++;
        document.getElementById('bf-n-notfound').textContent = notFound;
        bfLog(`✗ ${r.artist} — ${r.title}`, 'fail');
      }

      done++;
      document.getElementById('bf-n-pending').textContent = Math.max(0, total - done);

      const delay = bfMode === 'art' ? 1200 : bfMode === 'tracks' ? 1000 : 700;
      await new Promise(res => setTimeout(res, delay));
    }
  }

  document.getElementById('bf-progress').style.width = '100%';
  document.getElementById('bf-current').textContent = `Done! ${found} found, ${notFound} not found.`;
  document.getElementById('bf-stop-btn').style.display = 'none';
  document.getElementById('bf-start-btn').textContent = '▶ Run Again';
  document.getElementById('bf-start-btn').style.display = 'inline-flex';
  renderAll(); updateStats();
  toast(`${BF_CONFIG[bfMode].label}: ${found} found, ${notFound} not found`);
}

async function fetchArtForRecord(r, attempt = 0) {
  try {
    const res = await fetch(
      `https://itunes.apple.com/search?term=${encodeURIComponent(r.artist+' '+r.title)}&entity=album&limit=5&media=music`
    );

    // Rate limited — iTunes returns 403 or non-ok when throttled
    if (res.status === 403 || res.status === 429) {
      if (attempt < 3) {
        const wait = (attempt + 1) * 3000; // 3s, 6s, 9s backoff
        bfLog(`⏳ Rate limited — waiting ${wait/1000}s before retry…`, 'skip');
        document.getElementById('bf-current').textContent = `Rate limit hit — pausing ${wait/1000}s…`;
        await new Promise(res => setTimeout(res, wait));
        return fetchArtForRecord(r, attempt + 1);
      }
      return null;
    }

    if (!res.ok) return null;
    const data = await res.json();

    // Empty results can also mean rate limiting — check resultCount
    if (!data.results?.length) {
      // If resultCount is 0 but we'd expect results, might be throttled
      if (attempt < 1) {
        await new Promise(res => setTimeout(res, 2000));
        return fetchArtForRecord(r, attempt + 1);
      }
      return null;
    }

    let best = data.results[0];
    if (r.year) {
      const ym = data.results.find(x => x.releaseDate?.startsWith(String(r.year)));
      if (ym) best = ym;
    }
    // Also try matching artist name for better accuracy
    const artistMatch = data.results.find(x =>
      x.artistName?.toLowerCase().includes(r.artist.toLowerCase().split(' ')[0])
    );
    if (artistMatch) best = artistMatch;

    return best.artworkUrl100 ? best.artworkUrl100.replace('100x100bb','600x600bb') : null;
  } catch(e) {
    if (attempt < 2) {
      await new Promise(res => setTimeout(res, 2000));
      return fetchArtForRecord(r, attempt + 1);
    }
    return null;
  }
}

async function fetchBioForRecord(r) {
  const clean = r.artist.replace(/^The /i,'').replace(/\s+feat\..*$/i,'').trim();
  for (const term of [clean, r.artist, `${clean} musician`]) {
    try {
      const s = await fetch(`https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(term)}&srlimit=3&format=json&origin=*`);
      const sd = await s.json();
      const hit = sd?.query?.search?.find(x => x.title.toLowerCase().includes(clean.toLowerCase())) || sd?.query?.search?.[0];
      if (!hit) continue;
      const e = await fetch(`https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exintro&explaintext&exsentences=10&pageids=${hit.pageid}&format=json&origin=*`);
      const ed = await e.json();
      const pages = ed?.query?.pages;
      const extract = pages?.[Object.keys(pages)[0]]?.extract?.trim();
      if (extract && extract.length > 80) {
        const paras = extract.split('\n').filter(p=>p.trim().length>30).slice(0,4);
        if (paras.length) return paras.join('\n\n');
      }
    } catch(e) {}
  }
  return null;
}

async function fetchDescForRecord(r) {
  const clean = r.artist.replace(/^The /i,'').replace(/\s+feat\..*$/i,'').trim();
  for (const term of [`${r.title} ${clean}`, `${r.title} album`, r.title]) {
    try {
      const s = await fetch(`https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(term)}&srlimit=3&format=json&origin=*`);
      const sd = await s.json();
      if (!sd?.query?.search?.length) continue;
      const hit = sd.query.search[0];
      const e = await fetch(`https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exintro&explaintext&exsentences=8&pageids=${hit.pageid}&format=json&origin=*`);
      const ed = await e.json();
      const pages = ed?.query?.pages;
      const extract = pages?.[Object.keys(pages)[0]]?.extract?.trim();
      if (!extract || extract.length < 60) continue;
      const lc = extract.toLowerCase();
      const titleWord = r.title.toLowerCase().split(' ').filter(w=>w.length>3)[0] || '';
      if (!lc.includes(clean.toLowerCase().split(' ')[0]) && !lc.includes(titleWord) && !lc.includes('album') && !lc.includes('music')) continue;
      const paras = extract.split('\n').filter(p=>p.trim().length>30).slice(0,3);
      if (paras.length) return paras.join('\n\n');
    } catch(e) {}
  }
  return null;
}

// Returns array of track names or null
async function fetchTracklistForRecord(r) {
  const MB_HEADERS = { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' };

  // Try strict search first: quoted title + artist
  const queries = [
    `release:"${r.title}" artist:"${r.artist}"`,
    `${r.title} ${r.artist}`,
    `${r.title}`
  ];

  for (const q of queries) {
    try {
      const res = await fetch(
        `https://musicbrainz.org/ws/2/release/?query=${encodeURIComponent(q)}&limit=5&fmt=json`,
        { headers: MB_HEADERS }
      );
      if (!res.ok) continue;
      const data = await res.json();
      if (!data.releases?.length) continue;

      // Prefer releases that match the year if we have one
      let releases = data.releases;
      if (r.year) {
        const yearMatches = releases.filter(x => x.date?.startsWith(String(r.year)));
        if (yearMatches.length) releases = yearMatches;
      }

      for (const rel of releases.slice(0, 3)) {
        try {
          await new Promise(res => setTimeout(res, 400)); // respect MB rate limit
          const detRes = await fetch(
            `https://musicbrainz.org/ws/2/release/${rel.id}?inc=recordings&fmt=json`,
            { headers: MB_HEADERS }
          );
          if (!detRes.ok) continue;
          const det = await detRes.json();
          const tracks = [];
          if (det.media) det.media.forEach(m => m.tracks?.forEach(t => tracks.push(t.title)));
          if (tracks.length >= 2) return tracks; // need at least 2 tracks to be valid
        } catch(e2) {}
      }
    } catch(e) {}
  }
  return null;
}

// ── Bulk credits fetch per track (returns enriched track obj or null) ──
async function fetchCreditsForTrack(record, trackName, idx) {
  const MB_HEADERS = { 'User-Agent': 'MRD-Records-App/1.0 (records@mrd.app)' };
  const obj = { ...trackObj(record.trackList[idx]) };
  try {
    const q = encodeURIComponent(`recording:"${trackName}" artist:"${record.artist}"`);
    const res = await fetch(
      `https://musicbrainz.org/ws/2/recording/?query=${q}&limit=3&fmt=json`,
      { headers: MB_HEADERS }
    );
    if (!res.ok) return null;
    const data = await res.json();
    if (!data.recordings?.length) return null;

    // Try to find best match with year context
    let rec = data.recordings[0];
    if (record.year) {
      const ym = data.recordings.find(x =>
        x.releases?.some(rel => rel.date?.startsWith(String(record.year)))
      );
      if (ym) rec = ym;
    }

    const duration = rec.length ? formatDuration(rec.length) : obj.duration;
    await new Promise(r => setTimeout(r, 500));

    // Fetch full recording with relations
    const detRes = await fetch(
      `https://musicbrainz.org/ws/2/recording/${rec.id}?inc=artist-credits+work-rels+recording-rels&fmt=json`,
      { headers: MB_HEADERS }
    );
    if (!detRes.ok) return { ...obj, duration: duration || obj.duration, enriched: true };
    const det = await detRes.json();

    const writers = [], producers = [];
    if (det.relations) {
      det.relations.forEach(rel => {
        if (['composer','lyricist','writer'].includes(rel.type) && rel.artist?.name)
          writers.push(rel.artist.name);
        if (['producer','co-producer'].includes(rel.type) && rel.artist?.name)
          producers.push(rel.artist.name);
      });
    }

    return {
      ...obj,
      duration:  duration || obj.duration,
      writers:   writers.length   ? writers.join(', ')   : obj.writers,
      producers: producers.length ? producers.join(', ') : obj.producers,
      mbid:      rec.id,
      enriched:  true
    };
  } catch(e) { return null; }
}

// ── Bulk lyrics fetch per track (returns enriched track obj or null) ──
async function fetchLyricsForTrackBulk(record, trackName, idx) {
  const obj = { ...trackObj(record.trackList[idx]) };
  try {
    const res = await fetch(
      `https://api.lyrics.ovh/v1/${encodeURIComponent(record.artist)}/${encodeURIComponent(trackName)}`
    );
    if (!res.ok) return null;
    const data = await res.json();
    if (!data.lyrics || data.lyrics.trim().length < 20) return null;
    return { ...obj, lyrics: data.lyrics.trim(), lyricsPartial: false };
  } catch(e) { return null; }
}



