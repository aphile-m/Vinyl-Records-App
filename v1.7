const DEVICE_KEY = 'mrd_trusted_device';

// ── Apply a session role (guest or admin) ────────────────
function applyRole(role, username) {
  currentUser = { username: username || (role === 'admin' ? 'admin' : 'guest'), role };
  const isAdm = role === 'admin';
  document.body.classList.toggle('is-admin', isAdm);

  // Badge
  const badge = document.getElementById('user-badge-display');
  badge.innerHTML = isAdm
    ? `<span class="user-badge badge-admin">⚡ Admin</span>`
    : `<span class="user-badge badge-readonly">👁 Browsing</span>`;

  // Header buttons
  const switchBtn = document.getElementById('admin-switch-btn');
  if (switchBtn) switchBtn.style.display = isAdm ? 'none' : 'flex';

  // Admin-only elements
  document.querySelectorAll('.admin-only').forEach(el => {
    el.style.display = isAdm ? 'flex' : 'none';
  });
  document.querySelectorAll('.admin-only-ta').forEach(el => {
    el.style.display = isAdm ? 'block' : 'none';
  });
  document.querySelectorAll('.admin-only-inline').forEach(el => {
    el.style.display = isAdm ? 'inline-flex' : 'none';
  });
}

// ── Guest auto-login (always happens on load) ────────────
function loginAsGuest() {
  applyRole('readonly', 'guest');
  renderAll();
}

// ── Admin login modal ────────────────────────────────────
function openAdminLogin() {
  document.getElementById('login-pass').value = '';
  document.getElementById('login-error').textContent = '';
  document.getElementById('admin-login-modal').classList.add('open');
  setTimeout(() => document.getElementById('login-pass').focus(), 200);
}

function closeAdminLogin() {
  document.getElementById('admin-login-modal').classList.remove('open');
}

function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  const errEl = document.getElementById('login-error');

  if (users[u] && users[u].password === p && users[u].role === 'admin') {
    // Check "remember this device"
    if (document.getElementById('trust-device').checked) {
      const token = btoa(`${u}:${p}:${navigator.userAgent.slice(0,40)}`);
      localStorage.setItem(DEVICE_KEY, JSON.stringify({ token, username: u }));
    }
    applyRole('admin', u);
    closeAdminLogin();
    renderAll();
    toast('⚡ Admin mode unlocked');
  } else if (users[u] && users[u].password === p && users[u].role !== 'admin') {
    errEl.textContent = 'That account does not have admin access.';
  } else {
    errEl.textContent = 'Incorrect password.';
  }
}

document.getElementById('login-pass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
document.getElementById('login-user').addEventListener('keydown', e => { if(e.key==='Enter') document.getElementById('login-pass').focus(); });

// ── Drop back to guest ────────────────────────────────────
function dropToGuest() {
  applyRole('readonly', 'guest');
  renderAll();
  toast('Switched to guest mode');
}

// ── Forget this device ────────────────────────────────────
function forgetDevice() {
  localStorage.removeItem(DEVICE_KEY);
  toast('Device forgotten — you will need to log in manually next time');
}

// ── Check trusted device on load ─────────────────────────
function checkTrustedDevice() {
  try {
    const saved = localStorage.getItem(DEVICE_KEY);
    if (!saved) return false;
    const { token, username } = JSON.parse(saved);
    // Re-derive and compare token
    const u = username;
    if (!users[u]) return false;
    const expected = btoa(`${u}:${users[u].password}:${navigator.userAgent.slice(0,40)}`);
    if (token === expected) {
      applyRole('admin', u);
      return true;
    }
    // Token mismatch (password changed) — clear it
    localStorage.removeItem(DEVICE_KEY);
    return false;
  } catch(e) { return false; }
}

function doLogout() {
  // Legacy — now just drops to guest
  dropToGuest();
}

function isAdmin() { return currentUser && currentUser.role === 'admin'; }

// ═══════════════════════════════════════════════════════
// FILTERS & SORTING
// ═══════════════════════════════════════════════════════
// ── Decade buckets for year filter ─────────────────────
function getDecades() {
  const years = DB.map(r=>r.year).filter(Boolean);
  const min = Math.floor(Math.min(...years)/10)*10;
  const max = Math.floor(Math.max(...years)/10)*10;
  const decades = [];
  for (let d = min; d <= max; d += 10) decades.push(d);
  return decades;
}

function populateFilterDropdowns() {
  const genres   = [...new Set(DB.map(r=>r.genre).filter(Boolean))].sort();
  const artists  = [...new Set(DB.map(r=>r.artist).filter(Boolean))].sort();
  const labels   = [...new Set(DB.map(r=>r.label).filter(Boolean))].sort();
  const decades  = getDecades();

  buildPills('genre-pills',  genres,  'genres',  g => g);
  buildPills('artist-pills', artists, 'artists', a => a);
  buildPills('label-pills',  labels,  'labels',  l => l);

  // Decade pills
  const yc = document.getElementById('year-pills');
  yc.innerHTML = decades.map(d =>
    `<button class="filter-pill decade" data-decade="${d}" onclick="toggleYearPill(${d},this)">${d}s</button>`
  ).join('');
}

function buildPills(containerId, values, filterKey, labelFn) {
  const c = document.getElementById(containerId);
  if (!c) return;
  c.innerHTML = values.map(v =>
    `<button class="filter-pill" data-val="${v.replace(/"/g,'&quot;')}" onclick="togglePill('${filterKey}','${v.replace(/'/g,"\'")}',this)">${labelFn(v)}</button>`
  ).join('');
}

function filterPillList(type) {
  const searchId = type + '-search';
  const pillsId  = type + '-pills';
  const q = document.getElementById(searchId)?.value.toLowerCase() || '';
  document.querySelectorAll(`#${pillsId} .filter-pill`).forEach(p => {
    p.style.display = p.dataset.val?.toLowerCase().includes(q) ? '' : 'none';
  });
}

function togglePill(filterKey, val, btn) {
  const arr = activeFilters[filterKey];
  const idx = arr.indexOf(val);
  if (idx === -1) arr.push(val);
  else arr.splice(idx, 1);
  btn.classList.toggle('active', arr.includes(val));
  updateFilterCounts();
  renderAll();
}

function toggleYearPill(decade, btn) {
  const idx = activeFilters.years.indexOf(decade);
  if (idx === -1) activeFilters.years.push(decade);
  else activeFilters.years.splice(idx, 1);
  btn.classList.toggle('active', activeFilters.years.includes(decade));
  renderAll();
}

function updateFilterCounts() {
  const gc = document.getElementById('genre-count');
  const ac = document.getElementById('artist-count');
  const lc = document.getElementById('label-count');
  if (gc) gc.textContent = activeFilters.genres.length ? `(${activeFilters.genres.length})` : '';
  if (ac) ac.textContent = activeFilters.artists.length ? `(${activeFilters.artists.length})` : '';
  if (lc) lc.textContent = activeFilters.labels.length ? `(${activeFilters.labels.length})` : '';
}

function applyFilters() {
  activeFilters.search  = document.getElementById('search-input').value.toLowerCase();
  activeFilters.yearFrom = document.getElementById('year-from')?.value || '';
  activeFilters.yearTo   = document.getElementById('year-to')?.value   || '';
  activeFilters.art      = document.getElementById('art-filter')?.value || '';
  sortBy = document.getElementById('sort-select').value;
  renderAll();
}

function setCollFilter(val, btn) {
  activeFilters.collection = val;
  document.querySelectorAll('#collection-filter button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAll();
}

function setStatusFilter(val, btn) {
  activeFilters.status = val;
  document.querySelectorAll('[data-status]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAll();
}

function clearFilters() {
  activeFilters = { search:'', genres:[], artists:[], labels:[], years:[], yearFrom:'', yearTo:'', status:'all', collection:'all', art:'' };
  document.getElementById('search-input').value = '';
  const yf = document.getElementById('year-from'); if (yf) yf.value = '';
  const yt = document.getElementById('year-to');   if (yt) yt.value = '';
  const af = document.getElementById('art-filter'); if (af) af.value = '';
  const gs = document.getElementById('genre-search');  if (gs) gs.value = '';
  const as = document.getElementById('artist-search'); if (as) as.value = '';
  const ls = document.getElementById('label-search');  if (ls) ls.value = '';
  document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('[data-col]').forEach(b => b.classList.toggle('active', b.dataset.col === 'all'));
  document.querySelectorAll('[data-status]').forEach(b => b.classList.toggle('active', b.dataset.status === 'all'));
  updateFilterCounts();
  renderAll();
}

function setSortBy(key) {
  sortBy = key;
  document.getElementById('sort-select').value = key;
  renderAll();
}

function getFiltered() {
  let records = DB.filter(r => {
    const s = activeFilters.search;
    if (s && !`${r.artist} ${r.title} ${r.label} ${r.genre} ${r.id}`.toLowerCase().includes(s)) return false;
    // Multi-select: genre must match ANY selected (substring match for compound genres)
    if (activeFilters.genres.length && !activeFilters.genres.some(g => (r.genre||'').toLowerCase().includes(g.toLowerCase()))) return false;
    if (activeFilters.artists.length && !activeFilters.artists.includes(r.artist)) return false;
    if (activeFilters.labels.length && !activeFilters.labels.includes(r.label)) return false;
    // Year range inputs
    if (activeFilters.yearFrom && (!r.year || r.year < +activeFilters.yearFrom)) return false;
    if (activeFilters.yearTo   && (!r.year || r.year > +activeFilters.yearTo))   return false;
    // Decade pills
    if (activeFilters.years.length && (!r.year || !activeFilters.years.some(d => r.year >= d && r.year < d+10))) return false;
    if (activeFilters.art === 'yes' && !r.albumArt) return false;
    if (activeFilters.art === 'no'  &&  r.albumArt) return false;
    if (activeFilters.collection === 'found'   && r.notes !== 'Found') return false;
    if (activeFilters.collection === 'neville' && r.notes !== "Neville's Collection") return false;
    if (activeFilters.status === 'listened'   && !r.listened)  return false;
    if (activeFilters.status === 'unlistened' &&  r.listened)  return false;
    if (activeFilters.status === 'fav'        && !r.favourite) return false;
    return true;
  });

  // Tag/playlist filter
  if (typeof activeTagFilter !== 'undefined' && activeTagFilter) {
    try {
      const tag = getAllTags().find(t => t.name === activeTagFilter);
      const ids = new Set(tag?.records || []);
      records = records.filter(r => ids.has(r.id));
    } catch(e) {}
  }

  records.sort((a,b) => {
    const av = (a[sortBy]||'').toString().toLowerCase();
    const bv = (b[sortBy]||'').toString().toLowerCase();
    return av < bv ? -1 : av > bv ? 1 : 0;
  });
  return records;
}

// ── Column order (grid metadata) ────────────────────────
const DEFAULT_COLS = [
  {key:'year',  label:'Year',   visible:true},
  {key:'genre', label:'Genre',  visible:true},
  {key:'label', label:'Label',  visible:false},
  {key:'notes', label:'Source', visible:false},
];

function getColumnOrder() {
  try {
    const saved = localStorage.getItem('mrd_cols');
    if (saved) return JSON.parse(saved);
  } catch(e) {}
  return JSON.parse(JSON.stringify(DEFAULT_COLS));
}

function saveColumnOrder(cols) {
  localStorage.setItem('mrd_cols', JSON.stringify(cols));
}

function getColValue(r, key) {
  const v = r[key];
  if (!v) return '';
  if (key === 'year') return String(v);
  if (typeof v === 'string' && v.length > 22) return v.substring(0,20)+'…';
  return String(v);
}

function openColOrder() {
  const cols = getColumnOrder();
  const list = document.getElementById('col-drag-list');
  list.innerHTML = cols.map((c,i) => `
    <li class="col-drag-item" draggable="true" data-idx="${i}"
      ondragstart="colDragStart(event,${i})" ondragover="colDragOver(event,${i})"
      ondrop="colDrop(event,${i})" ondragleave="colDragLeave(event)"
      ondragend="colDragEnd(event)">
      <span class="col-drag-handle">⠿</span>
      <span class="col-drag-name">${c.label}</span>
      <div class="col-drag-toggle ${c.visible?'on':''}" onclick="toggleColVisible(${i},this)"></div>
    </li>`).join('');
  document.getElementById('colorder-modal').classList.add('open');
}

function closeColOrder() {
  document.getElementById('colorder-modal').classList.remove('open');
  renderAll();
}

function resetColOrder() {
  saveColumnOrder(JSON.parse(JSON.stringify(DEFAULT_COLS)));
  openColOrder();
  renderAll();
}

function toggleColVisible(idx, el) {
  const cols = getColumnOrder();
  cols[idx].visible = !cols[idx].visible;
  el.classList.toggle('on', cols[idx].visible);
  saveColumnOrder(cols);
  renderAll();
}

let dragSrcIdx = null;
function colDragStart(e, idx) {
  dragSrcIdx = idx;
  e.currentTarget.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function colDragOver(e, idx) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.querySelectorAll('.col-drag-item').forEach(el => el.classList.remove('drag-over'));
  e.currentTarget.classList.add('drag-over');
}
function colDragLeave(e) { e.currentTarget.classList.remove('drag-over'); }
function colDragEnd(e) {
  document.querySelectorAll('.col-drag-item').forEach(el => {
    el.classList.remove('dragging','drag-over');
  });
}
function colDrop(e, targetIdx) {
  e.preventDefault();
  if (dragSrcIdx === null || dragSrcIdx === targetIdx) return;
  const cols = getColumnOrder();
  const [moved] = cols.splice(dragSrcIdx, 1);
  cols.splice(targetIdx, 0, moved);
  saveColumnOrder(cols);
  dragSrcIdx = null;
  openColOrder(); // re-render the list
  renderAll();
}

// ═══════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════
function renderAll() {
  filteredRecords = getFiltered();
  const count = filteredRecords.length;
  document.getElementById('toolbar-info').textContent = `${count} of ${DB.length} records`;
  document.getElementById('sidebar-count').textContent = `Showing ${count} records`;
  document.getElementById('header-stats').textContent = `${DB.length} records`;
  document.getElementById('empty-state').classList.toggle('hidden', count > 0);

  if (currentView === 'grid') {
    renderGrid();
    document.getElementById('catalogue-grid').classList.remove('hidden');
    document.getElementById('catalogue-list').classList.add('hidden');
  } else {
    renderList();
    document.getElementById('catalogue-list').classList.remove('hidden');
    document.getElementById('catalogue-grid').classList.add('hidden');
  }
  updateStats();
}

function getGenreColor(genre) {
  const map = {
    'Funk':'#e8a020','Soul':'#c47b2e','Jazz':'#4a8fd4','Disco':'#9b59b6','Rock':'#e05252',
    'Gospel':'#52c478','Blues':'#3a7bd5','R&B':'#e88020','Country':'#7d6b4a','Pop':'#d4598a',
    'Hip Hop':'#2ecc71','Classical':'#9b8fa0','South African':'#f39c12'
  };
  for (const [k,v] of Object.entries(map)) {
    if (genre && genre.toLowerCase().includes(k.toLowerCase())) return v;
  }
  return '#4a4a4a';
}

function getArtistEmoji(genre) {
  if (!genre) return '🎵';
  const g = genre.toLowerCase();
  if (g.includes('jazz')) return '🎷';
  if (g.includes('gospel') || g.includes('choral')) return '🙏';
  if (g.includes('blues')) return '🎸';
  if (g.includes('classical')) return '🎻';
  if (g.includes('country')) return '🤠';
  if (g.includes('hip hop')) return '🎤';
  if (g.includes('rock')) return '🎸';
  if (g.includes('disco')) return '💿';
  if (g.includes('funk')) return '🎹';
  if (g.includes('soul')) return '🎙';
  return '🎵';
}

function renderGrid() {
  const grid = document.getElementById('catalogue-grid');
  const cols = getColumnOrder();
  grid.innerHTML = filteredRecords.map(r => {
    const color = getGenreColor(r.genre);
    const emoji = getArtistEmoji(r.genre);
    const artHTML = r.albumArt
      ? `<img class="album-art" src="${r.albumArt}" alt="${r.title}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
      : '';
    const placeholderStyle = r.albumArt ? 'display:none' : '';
    let artBadge = '';
    if (r.albumArt && r.artStatus === 'auto') {
      artBadge = '<div class="art-status-badge art-status-auto" title="Auto-fetched, not yet verified">Auto</div>';
    } else if (r.albumArt && r.artStatus === 'verified') {
      artBadge = '<div class="art-status-badge art-status-verified" title="Art verified by admin">✓ OK</div>';
    }
    // Build metadata rows based on column order prefs
    const metaRows = cols.filter(c => c.visible).map(c => {
      const val = getColValue(r, c.key);
      if (!val) return '';
      return `<div class="card-meta-row"><span class="card-meta-label">${c.label}</span><span class="card-meta-val">${val}</span></div>`;
    }).join('');
    return `<div class="album-card" onclick="openDetail('${r.id}')">
      ${artHTML}
      <div class="card-placeholder" style="${placeholderStyle};background:linear-gradient(135deg,${color}22,${color}44)">
        <div class="ph-icon">${emoji}</div>
        <div class="ph-artist">${r.artist}</div>
        <div class="ph-title">${r.title}</div>
      </div>
      <div class="card-info-overlay">
        <div class="cio-artist">${r.artist}</div>
        <div class="cio-title">${r.title}</div>
        <div class="cio-meta">${metaRows}</div>
      </div>
      ${artBadge}
      <div class="card-badges">
        ${r.listened ? '<div class="badge badge-listened" title="Listened">✓</div>' : ''}
        ${r.favourite ? '<div class="badge badge-fav" title="Favourite">★</div>' : ''}
      </div>
    </div>`;
  }).join('');
}

function renderList() {
  const rows = document.getElementById('list-rows');
  rows.innerHTML = filteredRecords.map((r,i) => {
    const thumbHTML = r.albumArt
      ? `<div class="list-thumb"><img src="${r.albumArt}" alt="" onerror="this.parentNode.textContent='${getArtistEmoji(r.genre)}'"></div>`
      : `<div class="list-thumb">${getArtistEmoji(r.genre)}</div>`;
    return `<div class="list-row" onclick="openDetail('${r.id}')">
      <span class="list-id">${r.id}</span>
      ${thumbHTML}
      <span class="list-artist">${r.artist}</span>
      <span class="list-title">${r.title}</span>
      <span class="list-genre">${r.genre||'—'}</span>
      <span class="list-year">${r.year||'—'}</span>
      <div class="list-flags">
        <span class="flag ${r.listened?'on':''}" title="Listened">✓</span>
        <span class="flag ${r.favourite?'on':''}" title="Favourite">★</span>
      </div>
      <div class="list-actions"></div>
    </div>`;
  }).join('');
}

function setView(v) {
  currentView = v;
  document.getElementById('view-grid').classList.toggle('active', v==='grid');
  document.getElementById('view-list').classList.toggle('active', v==='list');
  renderAll();
}

// ═══════════════════════════════════════════════════════
// STATS
// ═══════════════════════════════════════════════════════
function updateStats() {
  const total = DB.length;
  const listened = DB.filter(r=>r.listened).length;
  const favs = DB.filter(r=>r.favourite).length;
  const withArt = DB.filter(r=>r.albumArt).length;
  const verified = DB.filter(r=>r.artStatus==='verified').length;
  const autoArt = DB.filter(r=>r.artStatus==='auto').length;
  const pct = total ? Math.round(listened/total*100) : 0;
  document.getElementById('sidebar-stats').innerHTML = `
    <div class="stat-box"><div class="sv">${total}</div><div class="sk">Total</div></div>
    <div class="stat-box"><div class="sv">${listened}</div><div class="sk">Listened</div></div>
    <div class="stat-box"><div class="sv">${favs}</div><div class="sk">Favourites</div></div>
    <div class="stat-box"><div class="sv">${withArt}</div><div class="sk">With Art</div></div>
  `;
  document.getElementById('listened-progress').style.width = pct + '%';
  document.getElementById('listened-label').textContent = `${pct}% of collection listened`;
  const coverageEl = document.getElementById('art-coverage-label');
  if (coverageEl) {
    const noArt = total - withArt;
    const withBio  = DB.filter(r=>r.artistBio).length;
    const verBio   = DB.filter(r=>r.bioStatus==='verified').length;
    const withDesc = DB.filter(r=>r.albumDesc).length;
    const verDesc  = DB.filter(r=>r.descStatus==='verified').length;
    coverageEl.innerHTML =
      `<b style="color:var(--text2)">Art:</b> <span style="color:var(--success)">✓${verified}</span> <span style="color:#c47b2e">◑${autoArt}</span> <span style="color:var(--text3)">○${noArt}</span><br>` +
      `<b style="color:var(--text2)">Bio:</b> <span style="color:var(--success)">✓${verBio}</span> <span style="color:#c47b2e">◑${withBio-verBio}</span> <span style="color:var(--text3)">○${total-withBio}</span><br>` +
      `<b style="color:var(--text2)">Info:</b> <span style="color:var(--success)">✓${verDesc}</span> <span style="color:#c47b2e">◑${withDesc-verDesc}</span> <span style="color:var(--text3)">○${total-withDesc}</span>`;
  }
}

// ═══════════════════════════════════════════════════════
// DETAIL MODAL
// ═══════════════════════════════════════════════════════
function openDetail(id) {
  currentRecord = DB.find(r => r.id === id);
  if (!currentRecord) return;
  const r = currentRecord;

  document.getElementById('d-id').textContent = r.id;
  document.getElementById('d-artist').textContent = r.artist;
  document.getElementById('d-title').textContent = r.title;

  // Meta tags
  const metas = [];
  if (r.year) metas.push(`<span class="meta-tag highlight">${r.year}</span>`);
  if (r.genre) metas.push(`<span class="meta-tag">${r.genre}</span>`);
  if (r.label) metas.push(`<span class="meta-tag">${r.label}</span>`);
  if (r.notes) metas.push(`<span class="meta-tag">${r.notes}</span>`);
  document.getElementById('d-meta').innerHTML = metas.join('');

  // Art
  const artImg = document.getElementById('d-art-img');
  const artPh = document.getElementById('d-art-placeholder');
  if (r.albumArt) {
    artImg.src = r.albumArt; artImg.style.display = 'block';
    artPh.style.display = 'none';
  } else {
    artImg.style.display = 'none';
    artPh.style.display = 'flex';
    artPh.textContent = getArtistEmoji(r.genre);
  }

  // Buttons
  document.getElementById('d-listen-btn').textContent = r.listened ? '✓ Mark Unlistened' : '◎ Mark as Listened';
  document.getElementById('d-fav-btn').textContent = r.favourite ? '★ Unfavourite' : '☆ Favourite';
  updateDetailArtStatus(r);

  // Tabs
  switchTab('info');
  renderDetailTracks();
  document.getElementById('d-album-desc').innerHTML = r.albumDesc
    ? r.albumDesc.split('\n').map(p=>`<p>${p}</p>`).join('')
    : '<em style="color:var(--text3)">No description yet.</em>';
  document.getElementById('d-artist-bio').innerHTML = r.artistBio
    ? r.artistBio.split('\n').map(p=>`<p>${p}</p>`).join('')
    : '<em style="color:var(--text3)">No biography yet.</em>';
  updateDetailBioStatus(r);
  updateDetailDescStatus(r);
  document.getElementById('d-play-count').textContent = r.playCount ? `▶ ${r.playCount}×` : '';
  renderDetailTags(r);

  // Notes
  const notesArea = document.getElementById('d-notes-area');
  const notesRO = document.getElementById('d-notes-readonly');
  if (isAdmin()) {
    notesArea.value = r.albumDesc || '';
    notesArea.style.display = 'block';
    notesRO.style.display = 'none';
  } else {
    notesRO.textContent = r.albumDesc || 'No notes.';
    notesArea.style.display = 'none';
    notesRO.style.display = 'block';
  }

  // Edit tab
  document.getElementById('e-artist').value = r.artist;
  document.getElementById('e-title').value = r.title;
  document.getElementById('e-genre').value = r.genre;
  document.getElementById('e-year').value = r.year||'';
  document.getElementById('e-label').value = r.label;
  document.getElementById('e-notes').value = r.notes;

  document.getElementById('detail-modal').classList.add('open');
}

function closeDetail() {
  document.getElementById('detail-modal').classList.remove('open');
  currentRecord = null;
}

function closeDetailOnBg(e) {
  if (e.target === document.getElementById('detail-modal')) closeDetail();
}

function switchTab(tab) {
  document.querySelectorAll('.detail-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  const idx = ['info','tracks','bio','notes','edit'].indexOf(tab);
  document.querySelectorAll('.detail-tab')[idx]?.classList.add('active');
  document.getElementById('tab-'+tab)?.classList.add('active');
}


