function renderAnalytics() {
  const total   = DB.length;
  const listened= DB.filter(r=>r.listened).length;
  const favs    = DB.filter(r=>r.favourite).length;
  const withArt = DB.filter(r=>r.albumArt).length;
  const played  = DB.filter(r=>r.playCount>0).length;
  const totalPlays = DB.reduce((s,r)=>s+(r.playCount||0),0);
  const withBio = DB.filter(r=>r.artistBio).length;

  document.getElementById('an-stats').innerHTML = [
    { n: total,      l: 'Records'    },
    { n: listened,   l: 'Listened'   },
    { n: favs,       l: 'Favourites' },
    { n: totalPlays, l: 'Total Plays'},
    { n: withArt,    l: 'With Art'   },
    { n: withBio,    l: 'With Bio'   },
  ].map(s => `<div class="an-stat"><div class="n">${s.n}</div><div class="l">${s.l}</div></div>`).join('');

  // Decades chart
  const decades = {};
  DB.forEach(r => {
    if (!r.year) return;
    const d = Math.floor(r.year/10)*10;
    if (!decades[d]) decades[d] = { total:0, listened:0 };
    decades[d].total++;
    if (r.listened) decades[d].listened++;
  });
  const maxD = Math.max(...Object.values(decades).map(d=>d.total));
  document.getElementById('an-decades').innerHTML = Object.entries(decades).sort(([a],[b])=>a-b).map(([d,v]) =>
    `<div class="an-bar-row">
      <div class="an-bar-label">${d}s</div>
      <div class="an-bar"><div class="an-bar-fill" style="width:${(v.total/maxD*100).toFixed(1)}%;background:linear-gradient(90deg,var(--accent),var(--accent2))"></div></div>
      <div class="an-bar-count">${v.total}</div>
    </div>`).join('');

  // Genre chart — normalise compound genres
  const genres = {};
  DB.forEach(r => {
    if (!r.genre) return;
    const g = r.genre.split(/[,\/]/)[0].trim();
    genres[g] = (genres[g]||0) + 1;
  });
  const topGenres = Object.entries(genres).sort(([,a],[,b])=>b-a).slice(0,10);
  const maxG = topGenres[0]?.[1] || 1;
  document.getElementById('an-genres').innerHTML = topGenres.map(([g,n]) =>
    `<div class="an-bar-row">
      <div class="an-bar-label" title="${g}">${g}</div>
      <div class="an-bar"><div class="an-bar-fill" style="width:${(n/maxG*100).toFixed(1)}%"></div></div>
      <div class="an-bar-count">${n}</div>
    </div>`).join('');

  // Top labels
  const labels = {};
  DB.forEach(r => { if (r.label) labels[r.label] = (labels[r.label]||0) + 1; });
  const topLabels = Object.entries(labels).sort(([,a],[,b])=>b-a).slice(0,8);
  const maxL = topLabels[0]?.[1] || 1;
  document.getElementById('an-labels').innerHTML = topLabels.map(([l,n]) =>
    `<div class="an-bar-row">
      <div class="an-bar-label" title="${l}">${l}</div>
      <div class="an-bar"><div class="an-bar-fill" style="width:${(n/maxL*100).toFixed(1)}%;background:var(--success)"></div></div>
      <div class="an-bar-count">${n}</div>
    </div>`).join('');

  // Most played
  const mostPlayed = DB.filter(r=>r.playCount>0).sort((a,b)=>b.playCount-a.playCount).slice(0,5);
  document.getElementById('an-mostplayed').innerHTML = mostPlayed.length ? mostPlayed.map(r =>
    `<div class="an-session-item" onclick="closeAnalytics();openDetail('${r.id}');event.stopPropagation()" style="cursor:pointer">
      <div class="an-session-art">${r.albumArt ? `<img src="${r.albumArt}" style="width:36px;height:36px;object-fit:cover;border-radius:4px">` : getArtistEmoji(r.genre)}</div>
      <div class="an-session-info"><div class="an-session-title">${r.artist}</div><div class="an-session-sub">${r.title}</div></div>
      <div class="an-session-time">▶ ${r.playCount}×</div>
    </div>`).join('') : '<div style="color:var(--text3);font-size:.85rem">No plays recorded yet</div>';

  // Recent sessions
  const sessions = JSON.parse(localStorage.getItem('mrd_sessions') || '[]').slice(0, 10);
  document.getElementById('an-sessions').innerHTML = sessions.length ? sessions.map(s => {
    const d = new Date(s.ts);
    const timeStr = d.toLocaleDateString('en-GB', {day:'numeric',month:'short'}) + ' ' + d.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
    return `<div class="an-session-item">
      <div class="an-session-art">${s.art ? `<img src="${s.art}" style="width:36px;height:36px;object-fit:cover;border-radius:4px">` : '🎵'}</div>
      <div class="an-session-info"><div class="an-session-title">${s.artist}</div><div class="an-session-sub">${s.title}</div></div>
      <div class="an-session-time">${timeStr}</div>
    </div>`;
  }).join('') : '<div style="color:var(--text3);font-size:.85rem">No listening sessions yet. Press ▶ Now Playing on a record to start!</div>';
}

// ═══════════════════════════════════════════════════════
// TAGS / PLAYLISTS
// ═══════════════════════════════════════════════════════
const TAGS_KEY = 'mrd_tags';
function getAllTags() {
  try { return JSON.parse(localStorage.getItem(TAGS_KEY) || '[]'); } catch(e) { return []; }
}
function saveTags(tags) { localStorage.setItem(TAGS_KEY, JSON.stringify(tags)); }

function openTagsModal() {
  renderAllTags();
  document.getElementById('tags-modal').classList.add('open');
}
function closeTagsModal() {
  document.getElementById('tags-modal').classList.remove('open');
}

function createTag() {
  const input = document.getElementById('new-tag-input');
  const name = input.value.trim();
  if (!name) return;
  const tags = getAllTags();
  if (tags.find(t => t.name === name)) { toast('Tag already exists', 'error'); return; }
  tags.push({ name, records: [] });
  saveTags(tags);
  input.value = '';
  renderAllTags();
  toast(`Tag "${name}" created`);
}

function deleteTag(name) {
  if (!confirm(`Delete tag "${name}"?`)) return;
  const tags = getAllTags().filter(t => t.name !== name);
  saveTags(tags);
  if (activeTagFilter === name) { activeTagFilter = null; renderAll(); }
  renderAllTags();
}

function renderAllTags() {
  const tags = getAllTags();
  const container = document.getElementById('all-tags-list');
  if (!tags.length) {
    container.innerHTML = '<div style="color:var(--text3);font-size:.85rem;padding:8px 0">No tags yet. Create one above.</div>';
    return;
  }
  container.innerHTML = tags.map(t => {
    const count = t.records?.length || 0;
    return `<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border)">
      <button class="tag-chip ${activeTagFilter===t.name?'active':''}" onclick="setTagFilter('${t.name.replace(/'/g,"\\'")}')">
        ${t.name} <span class="tag-record-count">${count}</span>
      </button>
      <div style="flex:1"></div>
      <button class="btn btn-ghost btn-sm admin-only" style="font-size:.72rem;padding:3px 8px" onclick="openTagRecordPicker('${t.name.replace(/'/g,"\\'")}')">+ Records</button>
      <button class="btn btn-ghost btn-sm admin-only" style="color:var(--danger);font-size:.72rem;padding:3px 8px" onclick="deleteTag('${t.name.replace(/'/g,"\\'")}')">✕</button>
    </div>`;
  }).join('');
  // Show admin-only inline
  if (isAdmin()) container.querySelectorAll('.admin-only').forEach(el => el.style.display = 'flex');
}

function setTagFilter(name) {
  activeTagFilter = activeTagFilter === name ? null : name;
  renderAllTags();
  renderAll();
  if (activeTagFilter) {
    const tag = getAllTags().find(t => t.name === name);
    document.getElementById('tag-section-title').textContent = `"${name}" — ${tag?.records?.length||0} records`;
    document.getElementById('tag-record-section').style.display = 'block';
    document.getElementById('tag-record-list').innerHTML = (tag?.records||[]).map(id => {
      const r = DB.find(x => x.id === id);
      return r ? `<div style="font-size:.83rem;padding:4px 0;color:var(--text2)">${r.artist} — ${r.title}</div>` : '';
    }).join('');
  } else {
    document.getElementById('tag-record-section').style.display = 'none';
  }
}

function clearTagFilter() {
  activeTagFilter = null;
  renderAllTags();
  renderAll();
  document.getElementById('tag-record-section').style.display = 'none';
}

function openTagRecordPicker(tagName) {
  // Simple: show all records as a searchable list with checkboxes
  const tag = getAllTags().find(t => t.name === tagName);
  if (!tag) return;
  const selected = new Set(tag.records || []);
  const picker = document.createElement('div');
  picker.style.cssText = 'position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.9);display:flex;align-items:center;justify-content:center';
  picker.innerHTML = `
    <div style="background:var(--surface);border-radius:16px;padding:24px;width:480px;max-width:95vw;max-height:80vh;overflow-y:auto">
      <h3 style="font-family:\'Bebas Neue\',sans-serif;color:var(--accent);font-size:1.4rem;margin-bottom:12px">Add to "${tagName}"</h3>
      <input type="text" placeholder="Search records…" oninput="filterTagPicker(this.value)" id="tag-picker-search" style="width:100%;margin-bottom:12px">
      <div id="tag-picker-list">${DB.map(r => `
        <label style="display:flex;align-items:center;gap:10px;padding:6px;cursor:pointer;border-radius:6px;transition:background .1s" onmouseover="this.style.background='var(--surface2)'" onmouseout="this.style.background=''">
          <input type="checkbox" ${selected.has(r.id)?'checked':''} data-id="${r.id}" style="width:auto;margin:0">
          <span style="font-size:.85rem">${r.artist} — ${r.title}</span>
        </label>`).join('')}</div>
      <div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end">
        <button class="btn btn-ghost" onclick="this.closest('div[style]').remove()">Cancel</button>
        <button class="btn btn-primary" onclick="saveTagRecords('${tagName.replace(/'/g,"\\'")}',this)">Save</button>
      </div>
    </div>`;
  document.body.appendChild(picker);
}

function filterTagPicker(q) {
  document.querySelectorAll('#tag-picker-list label').forEach(el => {
    el.style.display = el.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}

function saveTagRecords(tagName, btn) {
  const tags = getAllTags();
  const tag = tags.find(t => t.name === tagName);
  if (!tag) return;
  const boxes = btn.closest('div').querySelectorAll('input[type=checkbox]');
  tag.records = [...boxes].filter(b => b.checked).map(b => b.dataset.id);
  saveTags(tags);
  btn.closest('[style*="position:fixed"]')?.remove();
  renderAllTags();
  renderAll();
  toast(`Tag "${tagName}" updated — ${tag.records.length} records`);
}

// Add tag to current record quickly from detail modal
function quickAddTag() {
  if (!currentRecord || !isAdmin()) return;
  const input = document.getElementById('d-tag-quick');
  const name = input.value.trim();
  if (!name) return;
  const tags = getAllTags();
  let tag = tags.find(t => t.name === name);
  if (!tag) { tag = { name, records: [] }; tags.push(tag); }
  if (!tag.records.includes(currentRecord.id)) tag.records.push(currentRecord.id);
  saveTags(tags);
  input.value = '';
  renderDetailTags(currentRecord);
  toast(`Added to "${name}"`);
}

function renderDetailTags(r) {
  const container = document.getElementById('d-tags-display');
  if (!container) return;
  const tags = getAllTags().filter(t => t.records?.includes(r.id));
  container.innerHTML = tags.length
    ? tags.map(t => `<span class="tag-chip active" style="cursor:default">${t.name}</span>`).join('')
    : '<span style="font-size:.78rem;color:var(--text3)">No tags yet</span>';
}

// Tag filter is handled inline in getFiltered


// ═══════════════════════════════════════════════════════
// AUDIO PREVIEW — singleton player
// ═══════════════════════════════════════════════════════
let _audio = null;
let _playingTrackIdx = null;   // index in current record's trackList
let _previewInterval = null;

function getAudio() {
  if (!_audio) {
    _audio = new Audio();
    _audio.volume = 0.8;
    _audio.addEventListener('ended', () => stopPreview());
    _audio.addEventListener('timeupdate', updatePreviewProgress);
    _audio.addEventListener('loadedmetadata', () => {
      const dur = document.getElementById('tp-dur-display');
      if (dur) dur.textContent = formatDuration(_audio.duration * 1000);
    });
  }
  return _audio;
}

function stopPreview(keepBtn) {
  if (_audio) { _audio.pause(); _audio.currentTime = 0; }
  clearInterval(_previewInterval);
  // Reset all preview buttons
  document.querySelectorAll('.preview-btn').forEach(b => {
    b.textContent = b.dataset.hasPreview === 'true' ? '▶' : '♪';
    b.classList.remove('playing', 'loading');
  });
  // Reset track page player
  const tpBtn = document.getElementById('tp-play-btn-main');
  if (tpBtn) { tpBtn.textContent = '▶'; tpBtn.classList.remove('loading'); }
  const fill = document.getElementById('tp-prog-fill');
  const handle = document.getElementById('tp-prog-handle');
  if (fill) fill.style.width = '0%';
  if (handle) handle.style.left = '0%';
  const cur = document.getElementById('tp-time-cur');
  if (cur) cur.textContent = '0:00';
  _playingTrackIdx = null;
}

function updatePreviewProgress() {
  if (!_audio || !_audio.duration) return;
  const pct = (_audio.currentTime / _audio.duration * 100).toFixed(1) + '%';
  const fill = document.getElementById('tp-prog-fill');
  const handle = document.getElementById('tp-prog-handle');
  const cur = document.getElementById('tp-time-cur');
  if (fill) fill.style.width = pct;
  if (handle) handle.style.left = pct;
  if (cur) cur.textContent = formatDuration(_audio.currentTime * 1000);
}

// ── Fetch preview URL from iTunes ─────────────────────
async function getPreviewUrl(trackName, artist, title) {
  // Check stored preview first
  if (!currentRecord) return null;
  const tracks = currentRecord.trackList || [];
  const obj = trackObj(tracks.find((t,i) => trackName === (trackObj(t).name || t)));
  if (obj.previewUrl) return obj.previewUrl;

  try {
    const q = encodeURIComponent(`${trackName} ${artist}`);
    const res = await fetch(`https://itunes.apple.com/search?term=${q}&entity=song&limit=5&media=music`);
    if (!res.ok) return null;
    const data = await res.json();
    if (!data.results?.length) return null;

    // Find best match — prefer one that matches the album
    let best = data.results.find(x =>
      x.trackName?.toLowerCase().includes(trackName.toLowerCase().split(' ').slice(0,3).join(' '))
    ) || data.results[0];

    return best?.previewUrl || null;
  } catch(e) { return null; }
}

// ── Toggle preview from tracklist ─────────────────────
async function toggleTrackPreview(idx) {
  if (!currentRecord) return;
  const tracks = currentRecord.trackList || [];
  const obj = trackObj(tracks[idx]);
  const name = obj.name || obj;
  const btn = document.getElementById(`prev-btn-${idx}`);

  // If this track is already playing — stop
  if (_playingTrackIdx === idx && _audio && !_audio.paused) {
    stopPreview();
    return;
  }

  // Stop any current playback
  stopPreview();
  _playingTrackIdx = idx;

  if (btn) { btn.classList.add('loading'); btn.textContent = '…'; }

  // Get or fetch preview URL
  let url = obj.previewUrl;
  if (!url) {
    url = await getPreviewUrl(name, currentRecord.artist, currentRecord.title);
    if (url) {
      // Cache it on the track object
      tracks[idx] = { ...obj, previewUrl: url };
      currentRecord.trackList = tracks;
      saveRecord(currentRecord);
    }
  }

  if (!url) {
    if (btn) { btn.classList.remove('loading'); btn.textContent = '♪'; }
    toast(`No 30s preview found for "${name}"`, 'error');
    _playingTrackIdx = null;
    return;
  }

  const audio = getAudio();
  audio.src = url;
  try {
    await audio.play();
    if (btn) {
      btn.textContent = '⏸';
      btn.classList.remove('loading');
      btn.classList.add('playing');
      btn.dataset.hasPreview = 'true';
    }
  } catch(e) {
    stopPreview();
    toast('Preview playback failed', 'error');
  }
}

// ── Build track page player HTML ──────────────────────
function buildTrackPlayer(obj, idx) {
  const hasStored = !!obj.previewUrl;
  return `<div class="tp-player" id="tp-player-${idx}">
    <button class="tp-player-btn" id="tp-play-btn-main" onclick="tpTogglePlay(${idx})" title="30-second preview">▶</button>
    <div style="flex:1;min-width:0">
      <div class="tp-progress-wrap" onclick="tpSeek(event)">
        <div class="tp-progress-bar" id="tp-prog-bar">
          <div class="tp-progress-fill" id="tp-prog-fill"></div>
          <div class="tp-progress-handle" id="tp-prog-handle"></div>
        </div>
      </div>
      <div class="tp-time">
        <span id="tp-time-cur">0:00</span>
        <span class="tp-preview-label">30s iTunes preview</span>
        <span id="tp-dur-display">0:30</span>
      </div>
    </div>
  </div>`;
}

function attachTrackPlayerEvents(obj, idx) {
  // If this track is currently playing, sync the UI
  if (_playingTrackIdx === idx && _audio && !_audio.paused) {
    const btn = document.getElementById('tp-play-btn-main');
    if (btn) btn.textContent = '⏸';
    updatePreviewProgress();
  }
}

async function tpTogglePlay(idx) {
  if (!currentRecord) return;
  const tracks = currentRecord.trackList || [];
  const obj = trackObj(tracks[idx]);
  const btn = document.getElementById('tp-play-btn-main');

  // If already playing this track — pause/resume
  if (_playingTrackIdx === idx && _audio) {
    if (_audio.paused) {
      await _audio.play();
      if (btn) btn.textContent = '⏸';
    } else {
      _audio.pause();
      if (btn) btn.textContent = '▶';
    }
    return;
  }

  // Stop whatever is playing
  stopPreview();
  _playingTrackIdx = idx;
  if (btn) { btn.classList.add('loading'); btn.textContent = '…'; }

  let url = obj.previewUrl;
  if (!url) {
    url = await getPreviewUrl(obj.name || obj, currentRecord.artist, currentRecord.title);
    if (url) {
      tracks[idx] = { ...obj, previewUrl: url };
      currentRecord.trackList = tracks;
      saveRecord(currentRecord);
      renderDetailTracks();
    }
  }

  if (!url) {
    if (btn) { btn.classList.remove('loading'); btn.textContent = '▶'; }
    // Replace player with "no preview" message
    const player = document.getElementById(`tp-player-${idx}`);
    if (player) player.outerHTML = `<div class="tp-no-preview">No 30s preview available for this track on iTunes. <a href="https://music.apple.com/search?term=${encodeURIComponent((obj.name||obj)+' '+currentRecord.artist)}" target="_blank" style="color:var(--accent)">Search Apple Music ↗</a></div>`;
    _playingTrackIdx = null;
    return;
  }

  const audio = getAudio();
  audio.src = url;
  try {
    await audio.play();
    if (btn) { btn.textContent = '⏸'; btn.classList.remove('loading'); }
    // Sync the list button too
    const listBtn = document.getElementById(`prev-btn-${idx}`);
    if (listBtn) { listBtn.textContent = '⏸'; listBtn.classList.add('playing'); }
  } catch(e) {
    stopPreview();
    if (btn) { btn.textContent = '▶'; btn.classList.remove('loading'); }
  }
}

function tpSeek(e) {
  if (!_audio || !_audio.duration || _playingTrackIdx === null) return;
  const bar = document.getElementById('tp-prog-bar');
  if (!bar) return;
  const rect = bar.getBoundingClientRect();
  const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
  _audio.currentTime = pct * _audio.duration;
  updatePreviewProgress();
}

// Stop audio when closing modals
const _origCloseTrackPage = typeof closeTrackPage !== 'undefined' ? closeTrackPage : null;
function closeTrackPage() {
  stopPreview();
  const modal = document.getElementById('trackpage-modal');
  modal.style.opacity = '0';
  modal.style.pointerEvents = 'none';
  currentTrackIdx = null;
}

function closeDetail() {
  stopPreview();
  document.getElementById('detail-modal').classList.remove('open');
  currentRecord = null;
}

function exportCSV() {
  const headers = ['ID','Artist','Title','Genre','Year','Label','Notes','Favourite','Listened','Tracks','FavTracks'];
  const rows = DB.map(r => [
    r.id, `"${r.artist}"`, `"${r.title}"`, `"${r.genre}"`, r.year||'', `"${r.label}"`, `"${r.notes}"`,
    r.favourite?'Yes':'No', r.listened?'Yes':'No', r.trackList?.length||0, r.favTracks?.length||0
  ]);
  const csv = [headers.join(','), ...rows.map(r=>r.join(','))].join('\n');
  download('mrd_catalogue.csv', csv, 'text/csv');
}

function exportJSON() {
  download('mrd_backup.json', JSON.stringify(DB, null, 2), 'application/json');
}

function backupData() {
  const backup = { db: DB, users, exported: new Date().toISOString() };
  download('mrd_full_backup.json', JSON.stringify(backup, null, 2), 'application/json');
  toast('Backup downloaded ✓');
}

function restoreData(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async (ev) => {
    try {
      const data = JSON.parse(ev.target.result);
      if (!confirm('This will replace ALL current data in the cloud database. Are you sure?')) return;
      if (data.db) {
        DB = data.db;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(DB));
        toast('Pushing data to cloud…');
        await saveBulk(DB);
      }
      if (data.users) { users = data.users; saveUsers(); }
      renderAll(); toast('Data restored & synced to cloud ✓');
    } catch(e) { toast('Invalid backup file', 'error'); }
  };
  reader.readAsText(file);
}

function download(filename, content, type) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], {type}));
  a.download = filename; a.click();
}

