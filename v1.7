function toggleNpTrack(i) {
  if (npDoneTracks.has(i)) npDoneTracks.delete(i);
  else npDoneTracks.add(i);
  renderNpTracks();
}

function toggleNpPlay() {
  npPlaying = !npPlaying;
  document.getElementById('np-play-btn').textContent = npPlaying ? '⏸' : '▶';
  if (npPlaying) {
    npInterval = setInterval(() => {
      npTimer++;
      const m = Math.floor(npTimer / 60);
      const s = String(npTimer % 60).padStart(2, '0');
      document.getElementById('np-timer').textContent = `${m}:${s}`;
    }, 1000);
    if (npSpinning) {
      const artImg = document.getElementById('np-art');
      artImg.classList.add('spinning');
    }
  } else {
    clearInterval(npInterval);
    document.getElementById('np-art').classList.remove('spinning');
  }
}

function toggleNpSpin() {
  npSpinning = !npSpinning;
  const artImg = document.getElementById('np-art');
  document.getElementById('np-spin-btn').style.color = npSpinning ? 'var(--accent)' : '';
  if (npPlaying) artImg.classList.toggle('spinning', npSpinning);
}

function closeNowPlaying() {
  npPlaying = false;
  clearInterval(npInterval);
  document.getElementById('np-art').classList.remove('spinning');
  document.getElementById('nowplaying-modal').classList.remove('open');
}

