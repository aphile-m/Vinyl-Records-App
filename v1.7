// ═══════════════════════════════════════════════════════
// Track objects: { name, duration, writers, producers, musicians, lyrics, lyricsPartial, mbid, enriched }
// Backward compat: plain strings are treated as {name: string}
function trackObj(t) {
  if (typeof t === 'string') return { name: t };
  return t || {};
}
function trackName(t) { return trackObj(t).name || ''; }

// ── Track column preferences ──────────────────────────
const TRACK_COLS_KEY = 'mrd_track_cols';
const DEFAULT_TRACK_COLS = [
  { key:'duration', label:'Duration', visible:true },
  { key:'writers',  label:'Writers',  visible:true },
  { key:'producers',label:'Producers',visible:false },
  { key:'lyrics',   label:'Has Lyrics',visible:true },
];
function getTrackCols() {
  try { return JSON.parse(localStorage.getItem(TRACK_COLS_KEY) || 'null') || JSON.parse(JSON.stringify(DEFAULT_TRACK_COLS)); }
  catch(e) { return JSON.parse(JSON.stringify(DEFAULT_TRACK_COLS)); }
}
function saveTrackCols(cols) { localStorage.setItem(TRACK_COLS_KEY, JSON.stringify(cols)); }

// ═══════════════════════════════════════════════════════
// ENHANCED renderDetailTracks
// ═══════════════════════════════════════════════════════
function renderDetailTracks() {
  if (!currentRecord) return;
  const list = document.getElementById('d-track-list');
  const tracks = currentRecord.trackList || [];
  if (!tracks.length) {
    list.innerHTML = '<li style="color:var(--text3);font-size:.85rem;padding:8px 0">No tracks added yet.</li>';
    return;
  }
  const cols = getTrackCols().filter(c => c.visible);
  const favs = currentRecord.favTracks || [];

  list.innerHTML = tracks.map((t, i) => {
    const obj = trackObj(t);
    const isFav = favs.includes(i);
    const adminDel = isAdmin() ? `<span class="track-del" onclick="removeTrack(${i},event)">✕</span>` : '';
    const enrichDot = obj.enriched ? '<span class="track-enriched-dot" title="Track data enriched"></span>' : '';

    // Extra col data shown in the list
    const extras = cols.map(c => {
      if (c.key === 'duration' && obj.duration) return `<span class="track-col-extra">${obj.duration}</span>`;
      if (c.key === 'writers' && obj.writers) return `<span class="track-col-extra" title="Writers">${obj.writers.split(',')[0].trim()}${obj.writers.includes(',') ? '…' : ''}</span>`;
      if (c.key === 'lyrics' && obj.lyrics) return `<span class="track-col-extra" title="Has lyrics">🎤</span>`;
      return '';
    }).filter(Boolean).join(' ');

    const hasPreview = !!obj.previewUrl;
    const previewIcon = hasPreview ? '▶' : '♪';
    return `<li class="track-item" onclick="openTrackPage(${i})" style="position:relative">
      <span class="track-num">${i+1}</span>
      <button class="preview-btn" id="prev-btn-${i}" data-has-preview="${hasPreview}" onclick="event.stopPropagation();toggleTrackPreview(${i})" title="${hasPreview ? '30s Preview' : 'Find & play preview'}">${previewIcon}</button>
      <span class="track-name">${obj.name || obj}${enrichDot}</span>
      <span style="flex:1;display:flex;align-items:center;gap:4px;justify-content:flex-end">${extras}</span>
      <span class="track-fav ${isFav?'on':''}" onclick="toggleTrackFav(${i},event)" title="Favourite track">★</span>
      ${adminDel}
    </li>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════
// TRACK PAGE
// ═══════════════════════════════════════════════════════
let currentTrackIdx = null;

function openTrackPage(idx) {
  if (!currentRecord) return;
  currentTrackIdx = idx;
  renderTrackPage(idx);
  const modal = document.getElementById('trackpage-modal');
  modal.style.opacity = '1';
  modal.style.pointerEvents = 'all';
}

function closeTrackPage() {
  const modal = document.getElementById('trackpage-modal');
  modal.style.opacity = '0';
  modal.style.pointerEvents = 'none';
  currentTrackIdx = null;
}

function renderTrackPage(idx) {
  const r = currentRecord;
  const tracks = r.trackList || [];
  const obj = trackObj(tracks[idx]);
  const name = obj.name || obj;
  const isFav = (r.favTracks || []).includes(idx);
  const total = tracks.length;

  const geniusUrl = `https://genius.com/search?q=${encodeURIComponent(name + ' ' + r.artist)}`;
  const whosampledUrl = `https://www.whosampled.com/search/?q=${encodeURIComponent(name + ' ' + r.artist)}`;
  const discogsUrl = `https://www.discogs.com/search/?q=${encodeURIComponent(r.artist + ' ' + r.title)}&type=release`;

  // Navigation
  const prevBtn = idx > 0 ? `<button class="tp-action-btn" onclick="renderTrackPage(${idx-1});currentTrackIdx=${idx-1}">← Prev</button>` : '';
  const nextBtn = idx < total-1 ? `<button class="tp-action-btn" onclick="renderTrackPage(${idx+1});currentTrackIdx=${idx+1}">Next →</button>` : '';

  // Credits section
  let creditsHtml = '';
  if (obj.writers || obj.producers || obj.musicians) {
    const rows = [];
    if (obj.writers)   rows.push(`<div class="tp-credit-row"><span class="tp-credit-role">Written by</span><span class="tp-credit-name">${obj.writers}</span></div>`);
    if (obj.producers) rows.push(`<div class="tp-credit-row"><span class="tp-credit-role">Produced by</span><span class="tp-credit-name">${obj.producers}</span></div>`);
    if (obj.musicians) rows.push(`<div class="tp-credit-row"><span class="tp-credit-role">Musicians</span><span class="tp-credit-name">${obj.musicians}</span></div>`);
    creditsHtml = `<div class="tp-section">
      <div class="tp-section-label">Credits ${obj.enriched ? '<span class="tp-enriched-badge">enriched</span>' : ''}</div>
      <div class="tp-credits">${rows.join('')}</div>
    </div>`;
  } else if (isAdmin()) {
    creditsHtml = `<div class="tp-section">
      <div class="tp-section-label">Credits</div>
      <div style="color:var(--text3);font-size:.83rem">No credits yet. <button class="btn btn-ghost btn-sm" onclick="enrichSingleTrack(${idx})">⚡ Fetch from MusicBrainz</button></div>
    </div>`;
  }

  // Lyrics section
  let lyricsHtml = '';
  if (obj.lyrics) {
    lyricsHtml = `<div class="tp-section">
      <div class="tp-section-label">Lyrics</div>
      <div class="tp-lyrics">${obj.lyrics}</div>
      ${obj.lyricsPartial ? '<div class="tp-lyrics-partial">Showing partial lyrics. <a href="' + geniusUrl + '" target="_blank" style="color:var(--accent)">Read full lyrics on Genius ↗</a></div>' : ''}
    </div>`;
  } else if (isAdmin()) {
    lyricsHtml = `<div class="tp-section">
      <div class="tp-section-label">Lyrics</div>
      <div style="color:var(--text3);font-size:.83rem">No lyrics yet. <button class="btn btn-ghost btn-sm" onclick="fetchLyricsForTrack(${idx})">🎤 Fetch Lyrics</button></div>
    </div>`;
  }

  // Admin edit fields
  const adminEdit = isAdmin() ? `<div class="tp-section">
    <div class="tp-section-label">Edit Track</div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <div style="display:flex;gap:8px;align-items:center"><label style="min-width:80px;font-size:.78rem;color:var(--text2)">Name</label><input type="text" value="${(obj.name||'').replace(/"/g,'&quot;')}" id="tp-name-${idx}" style="flex:1;font-size:.85rem"></div>
      <div style="display:flex;gap:8px;align-items:center"><label style="min-width:80px;font-size:.78rem;color:var(--text2)">Duration</label><input type="text" value="${obj.duration||''}" id="tp-dur-${idx}" placeholder="e.g. 3:42" style="flex:1;font-size:.85rem"></div>
      <div style="display:flex;gap:8px;align-items:center"><label style="min-width:80px;font-size:.78rem;color:var(--text2)">Writers</label><input type="text" value="${(obj.writers||'').replace(/"/g,'&quot;')}" id="tp-wri-${idx}" placeholder="e.g. Marvin Gaye" style="flex:1;font-size:.85rem"></div>
      <div style="display:flex;gap:8px;align-items:center"><label style="min-width:80px;font-size:.78rem;color:var(--text2)">Producers</label><input type="text" value="${(obj.producers||'').replace(/"/g,'&quot;')}" id="tp-pro-${idx}" style="flex:1;font-size:.85rem"></div>
      <div style="display:flex;gap:8px;align-items:center"><label style="min-width:80px;font-size:.78rem;color:var(--text2)">Musicians</label><input type="text" value="${(obj.musicians||'').replace(/"/g,'&quot;')}" id="tp-mus-${idx}" style="flex:1;font-size:.85rem"></div>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:4px">
        <button class="btn btn-ghost btn-sm" onclick="enrichSingleTrack(${idx})">⚡ Enrich from MusicBrainz</button>
        <button class="btn btn-primary btn-sm" onclick="saveTrackEdit(${idx})">💾 Save</button>
      </div>
    </div>
  </div>` : '';

  // Build player HTML
  const playerHtml = buildTrackPlayer(obj, idx);

  document.getElementById('trackpage-content').innerHTML = `
    <div class="tp-header">
      <div class="tp-num">${idx + 1}</div>
      <div style="flex:1;min-width:0">
        <div class="tp-title">${name}</div>
        <div class="tp-album">${r.artist} — ${r.title}${r.year ? ` (${r.year})` : ''}</div>
        ${obj.duration ? `<div class="tp-duration">${obj.duration}</div>` : ''}
      </div>
    </div>
    ${playerHtml}
    <div class="tp-actions">
      <span class="track-fav ${isFav?'on':''}" style="cursor:pointer;font-size:1.1rem;padding:5px 8px;border-radius:20px;border:1px solid var(--border)" onclick="toggleTrackFav(${idx},{stopPropagation:()=>{}});renderTrackPage(${idx})" title="Favourite">★</span>
      <a class="tp-action-btn genius" href="${geniusUrl}" target="_blank">🎤 Genius</a>
      <a class="tp-action-btn whosampled" href="${whosampledUrl}" target="_blank">🔁 WhoSampled</a>
      <a class="tp-action-btn" href="${discogsUrl}" target="_blank">💿 Discogs</a>
      ${prevBtn}${nextBtn}
    </div>
    ${creditsHtml}
    ${lyricsHtml}
    ${adminEdit}
  `;
  // Attach player events after render
  attachTrackPlayerEvents(obj, idx);
}

function saveTrackEdit(idx) {
  if (!currentRecord || !isAdmin()) return;
  const tracks = currentRecord.trackList || [];
  const obj = { ...trackObj(tracks[idx]) };
  const nameEl = document.getElementById(`tp-name-${idx}`);
  if (nameEl) obj.name = nameEl.value.trim();
  const dur = document.getElementById(`tp-dur-${idx}`);
  if (dur) obj.duration = dur.value.trim();
  const wri = document.getElementById(`tp-wri-${idx}`);
  if (wri) obj.writers = wri.value.trim();
  const pro = document.getElementById(`tp-pro-${idx}`);
  if (pro) obj.producers = pro.value.trim();
  const mus = document.getElementById(`tp-mus-${idx}`);
  if (mus) obj.musicians = mus.value.trim();
  tracks[idx] = obj;
  currentRecord.trackList = tracks;
  saveRecord(currentRecord);
  renderDetailTracks();
  renderTrackPage(idx);
  toast('Track saved ✓');
}

